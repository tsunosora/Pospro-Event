model StockPurchaseItem {
  id               Int      @id @default(autoincrement())
  purchaseId       Int      @map("purchase_id")
  productVariantId Int      @map("product_variant_id")
  quantity         Int
  unitPrice        Decimal? @db.Decimal(15, 2) @map("unit_price")

  purchase       StockPurchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
