model BankAccount {
  id             Int       @id @default(autoincrement())
  bankName       String    @map("bank_name") @db.VarChar(100)
  accountNumber  String    @map("account_number") @db.VarChar(100)
  accountOwner   String    @map("account_owner") @db.VarChar(100)
  currentBalance Decimal   @default(0) @map("current_balance") @db.Decimal(15, 2)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime? @default(now()) @map("created_at")
  updatedAt      DateTime? @default(now()) @updatedAt @map("updated_at")

  transactions Transaction[]
  cashflows    Cashflow[]
  invoicePayments InvoicePayment[]

  @@map("bank_accounts")
}

/**
 * InvoicePayment — record per-cicilan untuk Invoice yang dibayar bertahap.
 * Setiap kali admin "Tandai Pembayaran Masuk", buat 1 row di tabel ini.
 * Invoice.paidAmount = sum dari InvoicePayment.amount untuk invoice tsb.
 * installmentNumber = 1, 2, 3, ... — auto-increment per invoice.
 */
model InvoicePayment {
  id                Int       @id @default(autoincrement())
  invoiceId         Int       @map("invoice_id")
  installmentNumber Int       @map("installment_number") // urutan cicilan: 1, 2, 3, ...
  amount            Decimal   @db.Decimal(15, 2)
  paidAt            DateTime  @map("paid_at")
  paymentMethod     String?   @map("payment_method") @db.VarChar(20) // CASH | QRIS | BANK_TRANSFER | OTHER
  paymentRef        String?   @map("payment_ref") @db.VarChar(200)
  paymentNote       String?   @map("payment_note") @db.Text
  paymentProofUrl   String?   @map("payment_proof_url") @db.VarChar(500)
  bankAccountId     Int?      @map("bank_account_id")
  cashflowId        Int?      @unique @map("cashflow_id") // FK ke Cashflow yang auto-created
  createdById       Int?      @map("created_by_id") // user yang record pembayaran
  createdAt         DateTime  @default(now()) @map("created_at")

  invoice     Invoice      @relation("InvoicePayments", fields: [invoiceId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([paidAt])
  @@map("invoice_payments")
}

/**
 * History perubahan jatuh tempo invoice (audit trail untuk owner).
 * Dibuat setiap kali admin extend tanggal pembayaran (mis. klien minta perpanjangan).
 * Owner bisa cek: berapa kali invoice ini di-extend, alasan apa, oleh siapa.
 */
model InvoiceDueDateHistory {
  id             Int       @id @default(autoincrement())
  invoiceId      Int       @map("invoice_id")
  oldDueDate     DateTime? @map("old_due_date")
  oldDueDateEnd  DateTime? @map("old_due_date_end")
  newDueDate     DateTime? @map("new_due_date")
  newDueDateEnd  DateTime? @map("new_due_date_end")
  /// Alasan perubahan — mis. "Klien belum ada uang, minta tunda 1 minggu"
  reason         String?   @db.Text
  changedById    Int?      @map("changed_by_id") // user yang ubah
  changedAt      DateTime  @default(now()) @map("changed_at")

  invoice Invoice @relation("InvoiceDueDateHistory", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, changedAt])
  @@map("invoice_due_date_history")
}

model Customer {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  phone       String?   @db.VarChar(50)
  email       String?   @db.VarChar(150)
  address     String?   @db.Text
  companyName String?   @db.VarChar(200) @map("company_name") // Nama perusahaan/instansi klien
  companyPIC  String?   @db.VarChar(150) @map("company_pic")  // Nama PIC/kontak person di klien
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at")

  salesOrders SalesOrder[]
  invoices    Invoice[]
  rabPlans    RabPlan[]
  events      Event[]
  lead        Lead?

  @@map("customers")
}

// ----- Stock Opname ----- //

enum OpnameStatus {
