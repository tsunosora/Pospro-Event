// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(20)
  users User[]

  @@map("roles")
}

model Branch {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  address   String?   @db.Text
  latitude  Decimal?  @db.Decimal(9, 6)
  longitude Decimal?  @db.Decimal(9, 6)
  omset     Decimal?  @default(0) @db.Decimal(15, 2) // Omset bulanan (Rp)
  margin    Decimal?  @default(0) @db.Decimal(5, 2) // Margin (%)
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("branches")
}

model Competitor {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(200)
  type      String?  @db.VarChar(100) // e.g., "Digital Printing", "Sablon"
  address   String?  @db.Text
  latitude  Decimal  @db.Decimal(9, 6)
  longitude Decimal  @db.Decimal(9, 6)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("competitors")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String?   @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  phone        String?   @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(200)
  roleId       Int?      @map("role_id")
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @default(now()) @map("updated_at")

  role      Role?      @relation(fields: [roleId], references: [id])
  cashflows Cashflow[]
  cashflowRequests    CashflowChangeRequest[]    @relation("CashflowRequests")
  cashflowReviews     CashflowChangeRequest[]    @relation("CashflowReviews")
  editRequests        TransactionEditRequest[]   @relation("EditRequests")
  editReviews         TransactionEditRequest[]   @relation("EditReviews")
  withdrawalsCreated  Withdrawal[]               @relation("WithdrawalCreatedBy")
  attendanceApprovals Attendance[]               @relation("AttendanceApprover")
  adjustmentsCreated  PayrollAdjustment[]        @relation("AdjustmentCreatedBy")
  attendanceAuditLogs AttendanceAuditLog[]       @relation("AuditChangedBy")

  @@map("users")
}

model Category {
  id             Int                  @id @default(autoincrement())
  name           String               @db.VarChar(100)
  parentId       Int?                 @map("parent_id")
  products       Product[]
  opnameSessions StockOpnameSession[]
  createdAt      DateTime?            @default(now()) @map("created_at")
  updatedAt      DateTime?            @default(now()) @updatedAt @map("updated_at")

  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("SubCategories")

  @@map("categories")
}

model Unit {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(50)
  products  Product[]
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("units")
}

model Product {
  id                 Int         @id @default(autoincrement())
  name               String      @db.VarChar(200)
  description        String?     @db.Text
  categoryId         Int         @map("category_id")
  unitId             Int         @map("unit_id")
  imageUrl           String?     @map("image_url") @db.Text
  imageUrls          String?     @map("image_urls") @db.Text
  pricingMode        PricingMode @default(UNIT) @map("pricing_mode")
  productType        ProductType @default(SELLABLE) @map("product_type")
  pricePerUnit       Decimal?    @map("price_per_unit") @db.Decimal(15, 2)
  requiresProduction Boolean     @default(false) @map("requires_production")
  hasAssemblyStage   Boolean     @default(false) @map("has_assembly_stage")
  trackStock         Boolean     @default(true) @map("track_stock")
  createdAt          DateTime?   @default(now()) @map("created_at")
  updatedAt          DateTime?   @default(now()) @updatedAt @map("updated_at")

  category      Category         @relation(fields: [categoryId], references: [id])
  unit          Unit             @relation(fields: [unitId], references: [id])
  variants      ProductVariant[]
  ingredients   Ingredient[]
  hppWorksheets HppWorksheet[]

  @@map("products")
}

model ProductVariant {
  id                      Int       @id @default(autoincrement())
  productId               Int       @map("product_id")
  sku                     String    @unique @db.VarChar(100)
  variantName             String?   @map("variant_name") @db.VarChar(100)
  price                   Decimal   @db.Decimal(15, 2)
  hpp                     Decimal   @default(0) @db.Decimal(15, 2)
  stock                   Int       @default(0)
  size                    String?   @db.VarChar(50)
  color                   String?   @db.VarChar(50)
  variantImageUrl         String?   @map("variant_image_url") @db.Text
  description             String?   @db.Text                                  // Keterangan / spesifikasi varian (mis. "Bahan kayu jati, ukuran 60x60cm")
  notes                   String?   @db.Text                                  // Catatan internal (mis. "Hanya untuk event premium")
  defaultWarehouseId      Int?      @map("default_warehouse_id")              // Gudang tempat barang ini biasanya disimpan
  isRollMaterial          Boolean   @default(false) @map("is_roll_material")
  rollPhysicalWidth       Decimal?  @map("roll_physical_width") @db.Decimal(10, 2)
  rollEffectivePrintWidth Decimal?  @map("roll_effective_print_width") @db.Decimal(10, 2)
  clicksPerUnit           Float?    @map("clicks_per_unit") // klik per unit terjual
  boothProductType        BoothProductType? @map("booth_product_type")       // SEWA atau PENGADAAN untuk pospenawaran
  defaultRentalUnit       String?   @db.VarChar(30) @map("default_rental_unit") // "hari", "m²", "unit", "set"
  sourceRabPlanId         Int?      @map("source_rab_plan_id")                 // RAB asal (bila varian dibuat dari RAB)
  createdAt               DateTime? @default(now()) @map("created_at")
  updatedAt               DateTime? @default(now()) @updatedAt @map("updated_at")

  product                 Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  defaultWarehouse        Warehouse?          @relation("VariantDefaultWarehouse", fields: [defaultWarehouseId], references: [id], onDelete: SetNull)
  batches                 Batch[]
  movements               StockMovement[]
  transactionItems        TransactionItem[]
  hppVariableCosts        HppVariableCost[]
  ingredientsAsRaw        Ingredient[]        @relation("RawMaterial")
  opnameItems             StockOpnameItem[]
  rollJobs                ProductionJob[]     @relation("RollUsedInJob")
  batchRolls              ProductionBatch[]   @relation("RollUsedInBatch")
  supplierItems           SupplierItem[]
  priceTiers              VariantPriceTier[]
  variantIngredients      VariantIngredient[] @relation("VariantBOM")
  variantIngredientsAsRaw VariantIngredient[] @relation("VariantRawMaterial")
  hppWorksheets           HppWorksheet[]
  purchaseItems           StockPurchaseItem[]
  salesOrderItems         SalesOrderItem[]
  invoiceItems            InvoiceItem[]
  rabItems                RabItem[]
  sourceRabPlan           RabPlan?            @relation("RabPlanGeneratedVariants", fields: [sourceRabPlanId], references: [id], onDelete: SetNull)
  withdrawalItems         WithdrawalItem[]
  packingItems            EventPackingItem[]
  promotedFromLooseItem   RabLooseItem?       @relation("LooseItemPromotedVariant")
  inventoryAcquisitions   InventoryAcquisition[] @relation("VariantAcquisitions")

  @@map("product_variants")
}

model RabLooseItem {
  id                Int       @id @default(autoincrement())
  description       String    @db.VarChar(255)
  normalizedKey     String    @unique @db.VarChar(255) @map("normalized_key")
  unit              String?   @db.VarChar(50)
  lastPriceRab      Decimal   @default(0) @db.Decimal(15, 2) @map("last_price_rab")
  lastPriceCost     Decimal   @default(0) @db.Decimal(15, 2) @map("last_price_cost")
  defaultCategory   String?   @db.VarChar(50) @map("default_category")
  notes             String?   @db.Text
  usageCount        Int       @default(0) @map("usage_count")
  lastUsedAt        DateTime? @map("last_used_at")
  promotedVariantId Int?      @unique @map("promoted_variant_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  promotedVariant   ProductVariant? @relation("LooseItemPromotedVariant", fields: [promotedVariantId], references: [id], onDelete: SetNull)

  @@index([usageCount])
  @@index([normalizedKey])
  @@map("rab_loose_items")
}

model Ingredient {
  id                   Int     @id @default(autoincrement())
  productId            Int     @map("product_id")
  name                 String  @db.VarChar(200)
  quantity             Decimal @db.Decimal(10, 3)
  unit                 String  @db.VarChar(50)
  price                Decimal @default(0) @db.Decimal(15, 2)
  subtotal             Decimal @default(0) @db.Decimal(15, 2)
  rawMaterialVariantId Int?    @map("raw_material_variant_id")

  product            Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterialVariant ProductVariant? @relation("RawMaterial", fields: [rawMaterialVariantId], references: [id], onDelete: SetNull)

  @@map("ingredients")
}

model Batch {
  id               Int       @id @default(autoincrement())
  productVariantId Int       @map("product_variant_id")
  batchNumber      String    @unique @map("batch_number") @db.VarChar(100)
  expirationDate   DateTime? @map("expiration_date") @db.Date
  stock            Int       @default(0)
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at")

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("batches")
}

enum BoothProductType {
  SEWA
  PENGADAAN
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum PricingMode {
  UNIT
  AREA_BASED
}

enum ProductType {
  SELLABLE
  RAW_MATERIAL
  SERVICE
}

model StockMovement {
  id               Int          @id @default(autoincrement())
  productVariantId Int          @map("product_variant_id")
  type             MovementType
  quantity         Decimal      @db.Decimal(10, 4)
  reason           String?      @db.VarChar(255)
  balanceAfter     Float?       @map("balance_after")
  referenceId      String?      @db.VarChar(100) @map("reference_id")
  date             DateTime?    @default(now())
  createdAt        DateTime?    @default(now()) @map("created_at")

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

enum PaymentMethod {
  CASH
  QRIS
  BANK_TRANSFER
}

enum TransactionStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
}

model Transaction {
  id                 Int               @id @default(autoincrement())
  invoiceNumber      String            @unique @map("invoice_number") @db.VarChar(100)
  totalAmount        Decimal           @map("total_amount") @db.Decimal(15, 2)
  tax                Decimal           @db.Decimal(15, 2)
  discount           Decimal           @default(0) @db.Decimal(15, 2)
  shippingCost       Decimal           @default(0) @map("shipping_cost") @db.Decimal(15, 2)
  grandTotal         Decimal           @map("grand_total") @db.Decimal(15, 2)
  paymentMethod      PaymentMethod     @map("payment_method")
  status             TransactionStatus @default(PENDING)
  customerName       String?           @map("customer_name") @db.VarChar(200)
  customerPhone      String?           @map("customer_phone") @db.VarChar(50)
  customerAddress    String?           @map("customer_address") @db.Text
  dueDate            DateTime?         @map("due_date")
  downPayment        Decimal           @default(0) @map("down_payment") @db.Decimal(15, 2)
  cashierName        String?           @map("cashier_name") @db.VarChar(100)
  employeeName       String?           @map("employee_name") @db.VarChar(100)
  bankAccountId      Int?              @map("bank_account_id")
  dpPaymentMethod    PaymentMethod?    @map("dp_payment_method")
  dpBankAccountId    Int?              @map("dp_bank_account_id")
  productionPriority String            @default("NORMAL") @map("production_priority") @db.VarChar(20)
  productionDeadline DateTime?         @map("production_deadline")
  productionNotes    String?           @map("production_notes") @db.Text
  checkoutNumber      String?           @unique @map("checkout_number") @db.VarChar(100)
  paidAt              DateTime?         @map("paid_at")
  checkoutCashierName String?           @map("checkout_cashier_name") @db.VarChar(100)
  createdAt          DateTime?         @default(now()) @map("created_at")
  updatedAt          DateTime?         @default(now()) @updatedAt @map("updated_at")

  items          TransactionItem[]
  bankAccount    BankAccount?           @relation(fields: [bankAccountId], references: [id])
  productionJobs ProductionJob[]
  printJobs      PrintJob[]
  editRequests   TransactionEditRequest[]
  salesOrder     SalesOrder?

  @@map("transactions")
}

model TransactionItem {
  id               Int       @id @default(autoincrement())
  transactionId    Int       @map("transaction_id")
  productVariantId Int       @map("product_variant_id")
  quantity         Int
  priceAtTime      Decimal   @map("price_at_time") @db.Decimal(15, 2)
  hppAtTime        Decimal   @default(0) @map("hpp_at_time") @db.Decimal(15, 2)
  widthCm          Decimal?  @map("width_cm") @db.Decimal(10, 2)
  heightCm         Decimal?  @map("height_cm") @db.Decimal(10, 2)
  areaCm2          Decimal?  @map("area_cm2") @db.Decimal(15, 4)
  pcs              Int?      @default(1)                         // jumlah kopi/PCS untuk AREA_BASED
  unitType         String?   @map("unit_type") @db.VarChar(10)  // 'm', 'cm', 'menit'
  note             String?   @db.Text
  clickType        String?   @map("click_type") @db.VarChar(50)  // "A3+ WARNA", "A4 BW", dll
  createdAt        DateTime? @default(now()) @map("created_at")

  transaction    Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  productionJob  ProductionJob?
  printJob       PrintJob?

  @@map("transaction_items")
}

enum CashflowType {
  INCOME
  EXPENSE
}

model Cashflow {
  id            Int            @id @default(autoincrement())
  type          CashflowType
  category      String         @db.VarChar(100)
  amount        Decimal        @db.Decimal(15, 2)
  note          String?        @db.Text
  userId        Int?           @map("user_id")
  bankAccountId Int?           @map("bank_account_id")
  paymentMethod  PaymentMethod? @map("payment_method")
  platformSource String?        @map("platform_source") @db.VarChar(100)
  date           DateTime       @default(now())
  shiftReportId    Int?     @map("shift_report_id") // tag pengeluaran ke shift tertentu
  excludeFromShift Boolean  @default(false) @map("exclude_from_shift") // true = tidak masuk laporan shift manapun (retroaktif/lupa)
  eventId       Int?           @map("event_id")     // tag ke event tertentu (untuk laba per project)
  rabPlanId     Int?           @map("rab_plan_id")  // tag ke RAB plan tertentu
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime?      @default(now()) @updatedAt @map("updated_at")

  user           User?        @relation(fields: [userId], references: [id])
  bankAccount    BankAccount? @relation(fields: [bankAccountId], references: [id])
  shiftReport    ShiftReport? @relation(fields: [shiftReportId], references: [id], onDelete: SetNull)
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  rabPlan        RabPlan?     @relation(fields: [rabPlanId], references: [id], onDelete: SetNull)
  changeRequests CashflowChangeRequest[]

  @@index([eventId])
  @@index([rabPlanId])
  @@map("cashflows")
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChangeRequestType {
  EDIT
  DELETE
}

model CashflowChangeRequest {
  id            Int                  @id @default(autoincrement())
  cashflowId    Int                  @map("cashflow_id")
  requesterId   Int                  @map("requester_id")
  type          ChangeRequestType
  status        ChangeRequestStatus  @default(PENDING)
  payload       Json?
  requesterNote String?              @map("requester_note") @db.Text
  reviewerNote  String?              @map("reviewer_note")  @db.Text
  reviewedBy    Int?                 @map("reviewed_by")
  reviewedAt    DateTime?            @map("reviewed_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @default(now()) @updatedAt @map("updated_at")

  cashflow  Cashflow @relation(fields: [cashflowId], references: [id], onDelete: Cascade)
  requester User     @relation("CashflowRequests", fields: [requesterId], references: [id])
  reviewer  User?    @relation("CashflowReviews",  fields: [reviewedBy],  references: [id])

  @@map("cashflow_change_requests")
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TransactionEditRequest {
  id            Int               @id @default(autoincrement())
  transactionId Int               @map("transaction_id")
  requestedById Int               @map("requested_by_id")
  reviewedById  Int?              @map("reviewed_by_id")
  status        EditRequestStatus @default(PENDING)
  reason        String            @db.Text
  editData      Json              @map("edit_data")
  reviewNote    String?           @map("review_note") @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")

  transaction  Transaction @relation(fields: [transactionId], references: [id])
  requestedBy  User        @relation("EditRequests", fields: [requestedById], references: [id])
  reviewedBy   User?       @relation("EditReviews",  fields: [reviewedById], references: [id])

  @@map("transaction_edit_requests")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID // Sebagian sudah dibayar (paidAmount > 0 tapi < amountToPay)
  CANCELLED
  ACCEPTED // Quotation accepted
  REJECTED // Quotation rejected
  EXPIRED // Quotation past valid date
}

enum InvoiceType {
  INVOICE
  QUOTATION
}

enum QuotationVariant {
  SEWA            // Sewa perlengkapan event
  PENGADAAN_BOOTH // Pengadaan booth special design
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique @map("invoice_number") @db.VarChar(100)
  type          InvoiceType   @default(INVOICE)
  clientName    String        @map("client_name") @db.VarChar(200)
  clientCompany String?       @map("client_company") @db.VarChar(200) // Instansi/PT
  clientAddress String?       @map("client_address") @db.Text // Alamat Lengkap
  clientPhone   String?       @map("client_phone") @db.VarChar(50) // No. HP/Telp
  clientEmail   String?       @map("client_email") @db.VarChar(150) // Email Perusahaan
  customerId    Int?          @map("customer_id")
  date          DateTime      @default(now())
  dueDate       DateTime?     @map("due_date") // Tanggal jatuh tempo (mode single date)
  /// Tanggal akhir jatuh tempo — kalau di-set, dueDate→dueDateEnd jadi RANGE.
  /// Mis. dueDate=15 Mei, dueDateEnd=20 Mei → "Jatuh tempo: 15-20 Mei 2026".
  /// Null = mode single date (cuma pakai dueDate).
  dueDateEnd    DateTime?     @map("due_date_end")
  validUntil    DateTime?     @map("valid_until") // Quotation: masa berlaku penawaran
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @default(0) @db.Decimal(15, 2)
  taxRate       Decimal       @default(0) @map("tax_rate") @db.Decimal(5, 2) // % PPN
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(15, 2) // Rp PPN
  /// PPh (Pajak Penghasilan / withholding tax) — biasanya PPh 23 (2%) atau PPh 4 ayat 2 (1.5%).
  /// PPh DIPOTONG dari total (klien transfer = total - PPh), jadi mengurangi nominal yang diterima vendor.
  /// Mis. event Rp 100jt + PPN 11% = Rp 111jt, dipotong PPh 2% = Rp 2.22jt → diterima Rp 108.78jt
  pphRate       Decimal       @default(0) @map("pph_rate") @db.Decimal(5, 2) // % PPh
  pphAmount     Decimal       @default(0) @map("pph_amount") @db.Decimal(15, 2) // Rp PPh (dipotong dari klien)
  discount      Decimal       @default(0) @db.Decimal(15, 2) // Diskon (Rp)
  total         Decimal       @default(0) @db.Decimal(15, 2) // Grand Total (Subtotal + PPN - Diskon)
  notes         String?       @db.Text // Syarat & Ketentuan, Garansi, dll
  // ----- Penawaran booth/event extensions ----- //
  quotationVariant  QuotationVariant? @map("quotation_variant")
  parentQuotationId Int?              @map("parent_quotation_id") // revisi merujuk ke penawaran induk
  revisionNumber    Int               @default(0) @map("revision_number") // 0 = original, 1,2,... = revisi ke-n
  projectName       String?           @map("project_name") @db.VarChar(200) // Nama event/proyek
  eventLocation     String?           @map("event_location") @db.VarChar(200)
  eventDateStart    DateTime?         @map("event_date_start")
  eventDateEnd      DateTime?         @map("event_date_end")
  // Multi-event support: array `[{name, location, dateStart, dateEnd}]` untuk event tambahan.
  // Event utama tetap pakai field projectName/eventLocation/eventDateStart/eventDateEnd di atas.
  additionalEvents  Json?             @map("additional_events")
  bankAccountIds    String?           @map("bank_account_ids") @db.VarChar(200) // CSV id bank yang dicantumkan di penawaran
  dpPercent         Decimal           @default(50) @map("dp_percent") @db.Decimal(5, 2)
  rabPlanId         Int?              @map("rab_plan_id")
  brand             EventBrand?
  signCity          String?           @map("sign_city") @db.VarChar(100) // Kota lokasi surat dibuat (mis. "Semarang"); kalau null pakai default dari brand address
  variantCode       String?           @map("variant_code") @db.VarChar(50) // FK-style ke QuotationVariantConfig.code; kalau null fallback ke enum quotationVariant
  signedByWorkerId  Int?              @map("signed_by_worker_id")          // Marketing/Sales yang menandatangani; kalau null pakai fallback director brand
  invoicePart       String?           @map("invoice_part") @db.VarChar(20)  // "DP" | "PELUNASAN" | "FULL" — untuk dokumen tipe INVOICE
  amountToPay       Decimal?          @map("amount_to_pay") @db.Decimal(15, 2) // Jumlah yang ditagihkan di invoice ini (mis. DP 50%); kalau null pakai total
  itemDisplayMode   String?           @map("item_display_mode") @db.VarChar(30) // "detailed" (default) | "category-summary" — sembunyikan harga per item, hanya total per kategori
  // Custom text per quotation — override default brand text. Null = pakai brandTexts dari BrandSettings.
  customOpeningText  String?           @map("custom_opening_text") @db.Text   // Override paragraf "Dengan hormat..." (full custom)
  customDisclaimer   String?           @map("custom_disclaimer") @db.Text     // Legacy: full override; default skip pakai prepend/append saja
  customPaymentTerms String?           @map("custom_payment_terms") @db.Text  // Legacy: full override
  customClosing      String?           @map("custom_closing") @db.Text        // Legacy: full override
  // ---- SPK-specific custom text (override saat render SPK saja, tidak pengaruh penawaran) ----
  customOpeningSpk     String?         @map("custom_opening_spk") @db.Text
  customDisclaimerSpk  String?         @map("custom_disclaimer_spk") @db.Text
  customPaymentTermsSpk String?        @map("custom_payment_terms_spk") @db.Text
  customClosingSpk     String?         @map("custom_closing_spk") @db.Text
  // Penanggung Jawab khusus SPK — kalau di-set, override clientName di SPK header.
  // Berguna ketika PIC yang tandatangan SPK berbeda dengan PIC di penawaran.
  spkPicName           String?         @map("spk_pic_name") @db.VarChar(150)
  spkPicPosition       String?         @map("spk_pic_position") @db.VarChar(100)
  spkPicPhone          String?         @map("spk_pic_phone") @db.VarChar(50)
  // Batas pelunasan SPK — tanggal selambat-lambatnya pelunasan dibayar.
  // Kalau null, render SPK fallback ke validUntil (legacy behavior).
  spkPaymentDeadline   DateTime?       @map("spk_payment_deadline")
  // ─── Payment tracking (Invoice) ─────────────────────────────────────────
  // Total nominal yang sudah dibayar (akumulasi kalau partial). Null = belum bayar.
  paidAmount           Decimal?        @map("paid_amount") @db.Decimal(15, 2)
  // Tanggal pembayaran terakhir (untuk full) atau terakhir update (untuk partial).
  paidAt               DateTime?       @map("paid_at")
  // Metode: TRANSFER / CASH / QRIS / OTHER
  paymentMethod        String?         @map("payment_method") @db.VarChar(20)
  // No. referensi (no. transfer, no. cek, bukti pembayaran)
  paymentRef           String?         @map("payment_ref") @db.VarChar(200)
  // Catatan bebas pembayaran (mis. "Bayar tunai via Pak Budi", "Dipotong PPh 2.5%")
  paymentNote          String?         @map("payment_note") @db.Text
  // URL ke gambar bukti transfer (upload manual oleh admin saat Mark Paid)
  paymentProofUrl      String?         @map("payment_proof_url") @db.VarChar(500)
  // Cancel info — kalau status=CANCELLED
  cancelledAt          DateTime?       @map("cancelled_at")
  cancelReason         String?         @map("cancel_reason") @db.VarChar(255)
  // FK ke Cashflow row yang auto-created saat Mark Paid (untuk traceability).
  paymentCashflowId    Int?            @unique @map("payment_cashflow_id")
  // ---- Invoice-specific custom text (override saat render Invoice saja, tidak pengaruh penawaran) ----
  customOpeningInvoice    String?      @map("custom_opening_invoice") @db.Text
  customDisclaimerInvoice String?      @map("custom_disclaimer_invoice") @db.Text
  customPaymentTermsInvoice String?    @map("custom_payment_terms_invoice") @db.Text
  customClosingInvoice    String?      @map("custom_closing_invoice") @db.Text
  // Penanggung Jawab khusus Invoice — kalau di-set, override clientName/Position/Phone di Invoice.
  // Berguna ketika PIC yang menerima tagihan invoice berbeda dengan PIC di penawaran (mis. ke Finance team).
  invoicePicName       String?         @map("invoice_pic_name") @db.VarChar(150)
  invoicePicPosition   String?         @map("invoice_pic_position") @db.VarChar(100)
  invoicePicPhone      String?         @map("invoice_pic_phone") @db.VarChar(50)
  // Append/prepend mode — text di atas/bawah default dari BrandSettings
  disclaimerPrepend     String?        @map("disclaimer_prepend") @db.Text
  disclaimerAppend      String?        @map("disclaimer_append") @db.Text
  paymentTermsPrepend   String?        @map("payment_terms_prepend") @db.Text
  paymentTermsAppend    String?        @map("payment_terms_append") @db.Text
  closingPrepend        String?        @map("closing_prepend") @db.Text
  closingAppend         String?        @map("closing_append") @db.Text
  attachmentCount    Int?              @map("attachment_count")                // Jumlah lampiran (mis. 1, 2, 3). Null = default 1.
  customAttachmentText String?         @map("custom_attachment_text") @db.Text // Override teks lampiran (mis. "Brosur produk, Foto referensi"). Null = pakai "{N} ({terbilang}) berkas".
  language           String            @default("id") @map("language") @db.VarChar(5) // "id" (default) atau "en"
  // Toggle mata uang USD — kalau true, label Rp diganti USD di semua nominal (TANPA konversi kurs).
  // Marketing input nilai USD manual ke field harga. Default false = pakai Rp.
  useUsdCurrency     Boolean           @default(false) @map("use_usd_currency")
  // Custom subject — override auto-derive dari variantLabel.
  // Contoh: "Booth Rental offering letter" (English) vs default "Penawaran Sewa Booth Special Design".
  customSubject      String?           @map("custom_subject") @db.VarChar(200)
  // Payment schedule multi-step — array `[{label, percent}]`. Total persen harus = 100.
  // Null = pakai dpPercent legacy (single DP + auto-pelunasan).
  paymentSchedule    Json?             @map("payment_schedule")
  // Specifications terpisah dari item table — list group dengan judul.
  // Format: `[{title?: string, items: string[]}]`. Render sebagai section setelah item table.
  specifications     Json?             @map("specifications")
  // Harga paket — alternatif untuk diskon dengan label lebih jelas.
  // Kalau di-set & > 0 → tampil "Total Penawaran / Harga Paket" di footer (PDF Nukahiji style).
  packagePrice       Decimal?          @map("package_price") @db.Decimal(15, 2)
  // Tampilkan grand total di footer? Default true. Set false untuk mode 'package' (PDF Jalakx).
  showGrandTotal     Boolean           @default(true) @map("show_grand_total")
  createdAt     DateTime?     @default(now()) @map("created_at")
  updatedAt     DateTime?     @default(now()) @updatedAt @map("updated_at")

  items    InvoiceItem[]
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  parent   Invoice?  @relation("QuotationRevisions", fields: [parentQuotationId], references: [id], onDelete: SetNull)
  children Invoice[] @relation("QuotationRevisions")
  rabPlan  RabPlan?  @relation("QuotationRabPlan", fields: [rabPlanId], references: [id], onDelete: SetNull)
  signedByWorker Worker? @relation("InvoiceSignedByWorker", fields: [signedByWorkerId], references: [id], onDelete: SetNull)
  payments InvoicePayment[] @relation("InvoicePayments")
  dueDateHistory InvoiceDueDateHistory[] @relation("InvoiceDueDateHistory")

  @@index([type, quotationVariant])
  @@index([parentQuotationId])
  @@index([brand])
  @@index([signedByWorkerId])
  @@map("invoices")
}

model InvoiceItem {
  id               Int     @id @default(autoincrement())
  invoiceId        Int     @map("invoice_id")
  description      String  @db.VarChar(255)
  unit             String? @db.VarChar(50) // Satuan: pcs, m², lembar, set, unit/hari, m²/hari
  quantity         Decimal @db.Decimal(15, 4) // desimal utk area m² / durasi
  /// Multiplier tambahan untuk sewa multi-faktor (hari, jam, dll).
  /// Subtotal = quantity × unitMultiplier × price.
  /// Mis. sewa 2 unit × 3 hari × Rp 350.000 → quantity=2, unitMultiplier=3, price=350000, subtotal=2.100.000
  /// Null/1 = item normal (qty × price). Tidak break kompatibilitas data lama.
  unitMultiplier   Decimal? @default(1) @map("unit_multiplier") @db.Decimal(10, 4)
  price            Decimal @db.Decimal(15, 2)
  orderIndex       Int     @default(0) @map("order_index")
  productVariantId Int?    @map("product_variant_id")
  categoryName     String? @map("category_name") @db.VarChar(100) // snapshot kategori RAB untuk grouping di PDF
  // Multi-event grouping: link item ke event tertentu (untuk penawaran multi-lokasi).
  // null = shared/global. 0 = event utama (projectName). 1+ = additionalEvents[i-1].
  eventIndex       Int?    @map("event_index")
  // Package grouping (mode 'package'): nama paket (mis. "Package 1", "Package 2"). null untuk mode normal.
  packageGroup     String? @map("package_group") @db.VarChar(80)

  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([invoiceId, orderIndex])
  @@index([invoiceId, eventIndex])
  @@index([invoiceId, packageGroup])
  @@map("invoice_items")
}

// ----- RAB (Rencana Anggaran Biaya) two-tier costing ----- //
model RabCategory {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(100)
  orderIndex Int       @default(0) @map("order_index")
  isActive   Boolean   @default(true) @map("is_active")
  // optional stable identifier (used for built-in/seeded categories)
  key        String?   @unique @db.VarChar(50)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")

  items RabItem[]

  @@index([orderIndex])
  @@map("rab_categories")
}

model RabPlan {
  id          Int         @id @default(autoincrement())
  code        String      @unique @db.VarChar(50)              // "RAB-2026-0037"
  title       String      @db.VarChar(255)
  projectName String?     @map("project_name") @db.VarChar(200)
  location    String?     @db.VarChar(200)
  periodStart DateTime?   @map("period_start")
  periodEnd   DateTime?   @map("period_end")
  customerId  Int?        @map("customer_id")
  brand       EventBrand?
  // Pendapatan
  dpAmount    Decimal   @default(0) @map("dp_amount") @db.Decimal(15, 2)
  pelunasan   Decimal   @default(0) @db.Decimal(15, 2)
  incomeOther Decimal   @default(0) @map("income_other") @db.Decimal(15, 2)
  notes       String?   @db.Text
  imageUrl    String?   @map("image_url") @db.Text  // Foto sketsa/desain/referensi project (single image)
  tags        String?   @db.Text  // JSON array of tag strings (e.g. ["Stand Standar 3x3", "Pengadaan"])
  reportCompletedAt DateTime? @map("report_completed_at")  // Admin manually mark laporan RAB sudah lengkap
  reportCompletedBy Int?      @map("report_completed_by")  // user ID yang menandai (audit)
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at")

  customer          Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items             RabItem[]
  quotations        Invoice[]         @relation("QuotationRabPlan")
  generatedVariants ProductVariant[]  @relation("RabPlanGeneratedVariants")
  events            Event[]           @relation("EventRabPlan")
  cashflows         Cashflow[]
  inventoryAcquisitions InventoryAcquisition[] @relation("RabPlanAcquisitions")

  @@index([brand])
  @@map("rab_plans")
}

model RabItem {
  id               Int      @id @default(autoincrement())
  rabPlanId        Int      @map("rab_plan_id")
  categoryId       Int      @map("category_id")
  orderIndex       Int      @default(0) @map("order_index")
  description      String   @db.VarChar(255)
  unit             String?  @db.VarChar(50)
  quantity         Decimal  @default(1) @db.Decimal(15, 4) // qty sisi RAB (client-facing)
  quantityCost     Decimal  @default(1) @map("quantity_cost") @db.Decimal(15, 4) // qty sisi COST (aktual/internal)
  priceRab         Decimal  @default(0) @map("price_rab") @db.Decimal(15, 2) // harga penawaran ke klien
  priceCost        Decimal  @default(0) @map("price_cost") @db.Decimal(15, 2) // harga aktual/internal (COST)
  productVariantId      Int?     @map("product_variant_id")
  sourcePackingItemId   Int?     @map("source_packing_item_id")
  notes                 String?  @db.Text
  isInventory           Boolean  @default(false) @map("is_inventory") // tag: barang yang dibeli sebagai aset perusahaan (bukan murni cost event)

  rabPlan            RabPlan           @relation(fields: [rabPlanId], references: [id], onDelete: Cascade)
  category           RabCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productVariant     ProductVariant?   @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  sourcePackingItem  EventPackingItem? @relation("PackingSourcedRabItems", fields: [sourcePackingItemId], references: [id], onDelete: SetNull)
  inventoryAcquisition InventoryAcquisition? @relation("RabItemAcquisition")

  @@index([rabPlanId, categoryId, orderIndex])
  @@index([sourcePackingItemId])
  @@index([isInventory])
  @@map("rab_items")
}

// ----- Counter nomor dokumen (penawaran, dll) ----- //
model DocumentNumberCounter {
  id        Int      @id @default(autoincrement())
  docType   String   @db.VarChar(20) @map("doc_type")  // "Pnwr"
  kode      String   @db.VarChar(20)                    // kode perusahaan: "Xp", "Ep"
  year      Int
  lastSeq   Int      @default(0) @map("last_seq")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([docType, kode, year])
  @@map("document_number_counters")
}

// ----- HPP Calculator & Recipe Templates ----- //

