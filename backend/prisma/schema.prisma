model ProductionBatch {
  id             Int       @id @default(autoincrement())
  batchNumber    String    @unique @map("batch_number") @db.VarChar(50)
  rollVariantId  Int?      @map("roll_variant_id")
  usedWaste      Boolean   @default(false) @map("used_waste")
  rollLengthUsed Decimal?  @map("roll_length_used") @db.Decimal(10, 2)
  status         String    @default("PROSES") @db.VarChar(20)
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime? @default(now()) @map("created_at")

  rollVariant ProductVariant? @relation("RollUsedInBatch", fields: [rollVariantId], references: [id])
