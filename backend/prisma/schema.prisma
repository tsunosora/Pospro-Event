  @@index([salesOrderId])
  @@map("sales_order_items")
}

model SalesOrderProof {
  id           Int      @id @default(autoincrement())
  salesOrderId Int      @map("sales_order_id")
  filename     String   @db.VarChar(500)
  caption      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
  @@map("sales_order_proofs")
}

// ----- Designer (login PIN tanpa akun) ----- //

model Designer {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  pin       String   @db.VarChar(10)
  isActive  Boolean  @default(true)  @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("designers")
}

// ----- Warehouse & Withdrawal (pengambilan barang dari gudang) ----- //

enum WithdrawalType {
  BORROW
  USE
}

enum WithdrawalStatus {
  CHECKED_OUT
  RETURNED
  PARTIAL_RETURNED
  OVERDUE
  CANCELLED
}

model Warehouse {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  address   String?  @db.VarChar(255)
  notes     String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  withdrawals Withdrawal[]
  storageLocations StorageLocation[]
  inventoryAcquisitions InventoryAcquisition[] @relation("WarehouseAcquisitions")
  defaultForVariants ProductVariant[] @relation("VariantDefaultWarehouse")

  @@map("warehouses")
}

model StorageLocation {
  id          Int       @id @default(autoincrement())
  warehouseId Int       @map("warehouse_id")
  code        String    @db.VarChar(50)
  name        String    @db.VarChar(150)
  notes       String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  packingItems EventPackingItem[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@map("storage_locations")
}

model Worker {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(100)                          // Nama panggilan / display (yang muncul di dropdown)
  fullName           String?  @map("full_name") @db.VarChar(150)        // Nama lengkap (untuk audit/HR record, opsional)
  position           String?  @db.VarChar(100)
  phone              String?  @db.VarChar(50)
  photoUrl           String?  @map("photo_url") @db.Text
  signatureImageUrl  String?  @map("signature_image_url") @db.Text   // Tanda tangan untuk surat penawaran
  /// Nama custom yang tampil di bawah TTD (kalau beda dari "name").
  /// Mis. `name`="Pak Budi" tapi di TTD perlu tampil "Budi Santoso, S.T." untuk formal letter.
  /// Null = pakai `name` sebagai fallback.
  signatureDisplayName String? @map("signature_display_name") @db.VarChar(150)
  stampImageUrl      String?  @map("stamp_image_url") @db.Text       // Stempel pribadi (optional, fallback ke brand stamp)
  isActive           Boolean  @default(true) @map("is_active")
  notes              String?  @db.Text
  // ─── Payroll fields ───────────────────────────────────────────────
  dailyWageRate         Decimal? @map("daily_wage_rate") @db.Decimal(12, 2)         // Gaji per hari (Rp). Null = belum di-set
  overtimeRatePerHour   Decimal? @map("overtime_rate_per_hour") @db.Decimal(12, 2)  // Tarif lembur per jam (Rp), mulai jam 17:00
  isPic                 Boolean  @default(false) @map("is_pic")                     // True = bisa dapat link absensi PIC
  picAccessToken        String?  @unique @map("pic_access_token") @db.VarChar(64)   // Token unik untuk public link PIC
  picPin                String?  @map("pic_pin") @db.VarChar(20)                    // PIN 4-6 digit untuk security tambahan saat akses public link
  teamId                Int?     @map("team_id")                                     // Worker member dari team mana (untuk filter PIC absensi)
  defaultCityKey        String?  @map("default_city_key") @db.VarChar(100)           // Default kota untuk wage resolution (preset PIC dropdown)
  defaultDivisionKey    String?  @map("default_division_key") @db.VarChar(100)       // Default divisi untuk wage resolution
  // ─────────────────────────────────────────────────────────────────
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  withdrawals        Withdrawal[]
  eventsAsPic        Event[]              @relation("EventPic")
  packingChecked     EventPackingItem[]   @relation("PackingCheckedBy")
  assignedLeads      Lead[]               @relation("LeadAssignedWorker")
  previousAssignedLeads Lead[]            @relation("LeadPreviousWorker")
  leadActivities     LeadActivity[]
  crewAssignments    EventCrewAssignment[]
  leadingTeams       CrewTeam[]           @relation("TeamLeader")
  signedQuotations   Invoice[]            @relation("InvoiceSignedByWorker")
  attendances        Attendance[]         @relation("WorkerAttendance")    // sebagai subjek absensi
  recordedAttendances Attendance[]        @relation("RecordedByPic")       // sebagai PIC yang merekam absensi
  team               CrewTeam?            @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  adjustments        PayrollAdjustment[]  @relation("WorkerAdjustments")    // tunjangan/potongan
  auditChangesAsPic  AttendanceAuditLog[] @relation("AuditChangedByPic")    // audit dari PIC

  @@map("workers")
}

/// Absensi harian — 1 row per worker per tanggal.
/// Wage resolution priority (di payroll-summary):
///   1. Kalau Attendance.eventId di-set & Event punya dailyWageRate → pakai Event override
///   2. Kalau Attendance.cityKey + divisionKey di-set & ada WageRate match → pakai matrix
///   3. Fallback: Worker.dailyWageRate (default)
model Attendance {
  id              Int              @id @default(autoincrement())
  workerId        Int              @map("worker_id")
  attendanceDate  DateTime         @map("attendance_date") @db.Date
  status          AttendanceStatus @default(ABSENT)
  overtimeHours   Decimal          @default(0) @map("overtime_hours") @db.Decimal(5, 2)
  notes           String?          @db.VarChar(255)
  recordedByPicId Int?             @map("recorded_by_pic_id")
  // Wage context — bisa kosong (fallback ke Worker default) atau di-set untuk override per-row
  eventId         Int?             @map("event_id")
  cityKey         String?          @map("city_key") @db.VarChar(100)
  divisionKey     String?          @map("division_key") @db.VarChar(100)
  // Approval flow — admin approve absensi PIC sebelum payroll final
  approvalStatus  AttendanceApprovalStatus @default(PENDING) @map("approval_status")
  approvedAt      DateTime?        @map("approved_at")
  approvedById    Int?             @map("approved_by_id")                            // User.id admin yang approve
  rejectionReason String?          @map("rejection_reason") @db.VarChar(500)
  recordedAt      DateTime         @default(now()) @map("recorded_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  worker          Worker           @relation("WorkerAttendance", fields: [workerId], references: [id], onDelete: Cascade)
  recordedByPic   Worker?          @relation("RecordedByPic", fields: [recordedByPicId], references: [id], onDelete: SetNull)
  event           Event?           @relation("EventAttendance", fields: [eventId], references: [id], onDelete: SetNull)
  approvedBy      User?            @relation("AttendanceApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  auditLogs       AttendanceAuditLog[]

  @@unique([workerId, attendanceDate])
  @@index([attendanceDate])
  @@index([recordedByPicId, attendanceDate])
  @@index([eventId])
  @@index([cityKey, divisionKey])
  @@index([approvalStatus, attendanceDate])
  @@map("attendances")
}

enum AttendanceApprovalStatus {
  PENDING    // PIC submit, menunggu approve admin
  APPROVED   // Admin approve, masuk payroll final
  REJECTED   // Admin reject, gak dihitung gaji
}

/// Audit log untuk attendance — simpan history setiap CREATE/UPDATE/DELETE/APPROVE/REJECT.
/// Old & new data disimpan sebagai JSON snapshot untuk forensik.
model AttendanceAuditLog {
  id              Int              @id @default(autoincrement())
  attendanceId    Int?             @map("attendance_id")           // nullable supaya log tetap ada walau attendance ter-hapus
  action          AuditAction
  changedById     Int?             @map("changed_by_id")            // User.id admin (kalau dari /payroll page)
  changedByPicId  Int?             @map("changed_by_pic_id")        // Worker.id PIC (kalau dari public link)
  oldData         String?          @db.Text                          // JSON snapshot sebelum perubahan
  newData         String?          @db.Text                          // JSON snapshot setelah perubahan
  notes           String?          @db.VarChar(500)
  createdAt       DateTime         @default(now()) @map("created_at")

  attendance      Attendance?      @relation(fields: [attendanceId], references: [id], onDelete: SetNull)
  changedBy       User?            @relation("AuditChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  changedByPic    Worker?          @relation("AuditChangedByPic", fields: [changedByPicId], references: [id], onDelete: SetNull)

  @@index([attendanceId, createdAt])
  @@index([action, createdAt])
  @@map("attendance_audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
}

/// Tunjangan / Potongan per worker per periode (mingguan/bulanan/custom).
/// Dipakai admin untuk tambah bonus, kasbon, denda, dll yang bukan dari attendance.
model PayrollAdjustment {
  id              Int                    @id @default(autoincrement())
  workerId        Int                    @map("worker_id")
  type            PayrollAdjustmentType
  amount          Decimal                @db.Decimal(12, 2)            // selalu positif. Sign ditentukan oleh `type`.
  effectiveDate   DateTime               @map("effective_date") @db.Date  // tanggal berlaku (untuk filter periode)
  notes           String?                @db.VarChar(500)
  createdById     Int?                   @map("created_by_id")          // User.id admin
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  worker          Worker                 @relation("WorkerAdjustments", fields: [workerId], references: [id], onDelete: Cascade)
  createdBy       User?                  @relation("AdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workerId, effectiveDate])
  @@index([effectiveDate])
  @@map("payroll_adjustments")
}

enum PayrollAdjustmentType {
  BONUS        // bonus performa — positif, tambah ke gaji
  ALLOWANCE    // tunjangan (transport, makan) — positif
  DEDUCTION    // potongan (denda, terlambat) — negatif (kurangi)
  ADVANCE      // kasbon — negatif (akan di-cair-kan dari gaji periode mendatang)
}

/// Master rate gaji per kombinasi (Kota, Divisi).
/// Mis. "Jakarta" + "Tukang Kayu" = Rp 200.000/hari + Rp 25.000/jam lembur.
/// Dipakai untuk resolve wage saat hitung payroll kalau Attendance.cityKey & divisionKey di-set.
model WageRate {
  id                  Int      @id @default(autoincrement())
  city                String   @db.VarChar(100)                              // nama kota (free text supaya match Customer.city)
  division            String   @db.VarChar(100)                              // nama divisi (free text, mis. "Tukang Kayu")
  dailyWageRate       Decimal  @map("daily_wage_rate") @db.Decimal(12, 2)
  overtimeRatePerHour Decimal  @map("overtime_rate_per_hour") @db.Decimal(12, 2)
  notes               String?  @db.VarChar(500)
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([city, division])
  @@index([isActive])
  @@map("wage_rates")
}

enum AttendanceStatus {
  FULL_DAY    // gaji penuh
  HALF_DAY    // 50% gaji
  ABSENT      // tidak hadir = 0 (lembur tetap dihitung)
}

model Withdrawal {
  id                 Int              @id @default(autoincrement())
  code               String           @unique @db.VarChar(50)
  workerId           Int              @map("worker_id")
  warehouseId        Int              @map("warehouse_id")
  eventId            Int?             @map("event_id")
  type               WithdrawalType
  status             WithdrawalStatus @default(CHECKED_OUT)
  purpose            String           @db.VarChar(255)
  scheduledReturnAt  DateTime?        @map("scheduled_return_at")
  actualReturnAt     DateTime?        @map("actual_return_at")
  checkoutPhotoUrl   String?          @map("checkout_photo_url") @db.Text
  returnPhotoUrl     String?          @map("return_photo_url") @db.Text
  notes              String?          @db.Text
  createdById        Int?             @map("created_by_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @default(now()) @updatedAt @map("updated_at")

  worker    Worker    @relation(fields: [workerId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("WithdrawalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     WithdrawalItem[]

  @@index([status])
  @@index([type, status])
  @@index([scheduledReturnAt])
  @@index([eventId])
  @@map("withdrawals")
}

model WithdrawalItem {
  id               Int     @id @default(autoincrement())
  withdrawalId     Int     @map("withdrawal_id")
  productVariantId Int     @map("product_variant_id")
  quantity         Decimal @db.Decimal(15, 4)
  returnedQty      Decimal @default(0) @db.Decimal(15, 4) @map("returned_qty")
  notes            String? @db.Text

  withdrawal     Withdrawal     @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([withdrawalId])
  @@map("withdrawal_items")
}

// ----- Event Scheduling ----- //

enum EventStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventBrand {
  EXINDO
  XPOSER
  OTHER
}

model Event {
  id             Int         @id @default(autoincrement())
  code           String      @unique @db.VarChar(50)
  name           String      @db.VarChar(255)
  brand          EventBrand  @default(EXINDO)
  status         EventStatus @default(SCHEDULED)
  venue          String?     @db.VarChar(255)
  customerId     Int?        @map("customer_id")
  customerName   String?     @db.VarChar(200) @map("customer_name")
  picWorkerId    Int?        @map("pic_worker_id")
  picName        String?     @db.VarChar(150) @map("pic_name")
  departureStart DateTime?   @map("departure_start")
  departureEnd   DateTime?   @map("departure_end")
  setupStart     DateTime?   @map("setup_start")
  setupEnd       DateTime?   @map("setup_end")
  loadingStart   DateTime?   @map("loading_start")
  loadingEnd     DateTime?   @map("loading_end")
  eventStart     DateTime?   @map("event_start")
  eventEnd       DateTime?   @map("event_end")
  notes          String?     @db.Text
  shareToken     String?     @unique @db.VarChar(64) @map("share_token")
  rabPlanId      Int?        @map("rab_plan_id")
  // Wage override per event/project — kalau di-set, override WageRate matrix & Worker default
  // Member rate: dipakai untuk semua worker di event ini
  dailyWageRate         Decimal? @map("daily_wage_rate") @db.Decimal(12, 2)
  overtimeRatePerHour   Decimal? @map("overtime_rate_per_hour") @db.Decimal(12, 2)
  // PIC rate (opsional): dipakai khusus untuk worker yang sama dengan event.picWorkerId.
  // Kalau null → PIC pakai member rate.
  dailyWageRatePic      Decimal? @map("daily_wage_rate_pic") @db.Decimal(12, 2)
  overtimeRatePerHourPic Decimal? @map("overtime_rate_per_hour_pic") @db.Decimal(12, 2)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @default(now()) @updatedAt @map("updated_at")

  customer         Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  picWorker        Worker?                @relation("EventPic", fields: [picWorkerId], references: [id], onDelete: SetNull)
  rabPlan          RabPlan?               @relation("EventRabPlan", fields: [rabPlanId], references: [id], onDelete: SetNull)
  withdrawals      Withdrawal[]
  packingItems     EventPackingItem[]
  crewAssignments  EventCrewAssignment[]
  cashflows        Cashflow[]
  attendances      Attendance[]            @relation("EventAttendance")

  @@index([status])
  @@index([eventStart])
  @@index([brand])
  @@map("events")
}

// ----- Event Crew Setup-Time Tracking ----- //
model CrewTeam {
  id              Int       @id @default(autoincrement())
  name            String    @unique @db.VarChar(80)
  leaderWorkerId  Int?      @map("leader_worker_id")
  color           String    @default("#6366f1") @db.VarChar(20)
  notes           String?   @db.Text
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  leader      Worker?               @relation("TeamLeader", fields: [leaderWorkerId], references: [id], onDelete: SetNull)
  assignments EventCrewAssignment[]
  members     Worker[]              @relation("TeamMembers")               // Permanent member untuk PIC absensi

  @@map("crew_teams")
}

model EventCrewAssignment {
  id              Int       @id @default(autoincrement())
  eventId         Int       @map("event_id")
  workerId        Int       @map("worker_id")
  teamId          Int?      @map("team_id")
  role            String?   @db.VarChar(80)
  scheduledStart  DateTime? @map("scheduled_start")
  scheduledEnd    DateTime? @map("scheduled_end")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  startPhotoUrl   String?   @map("start_photo_url") @db.Text
  endPhotoUrl     String?   @map("end_photo_url") @db.Text
  startNote       String?   @db.Text @map("start_note")
  endNote         String?   @db.Text @map("end_note")
  accessToken     String    @unique @map("access_token") @db.VarChar(64)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  event  Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  worker Worker    @relation(fields: [workerId], references: [id])
  team   CrewTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([eventId, workerId])
  @@index([eventId])
  @@index([workerId])
  @@index([teamId])
  @@map("event_crew_assignments")
}

enum PackingDisposition {
  PINJAM
  OPERASIONAL
}

model EventPackingItem {
  id                Int                 @id @default(autoincrement())
  eventId           Int                 @map("event_id")
  productVariantId  Int                 @map("product_variant_id")
  quantity          Decimal             @default(1) @db.Decimal(15, 4)
  storageLocationId Int?                @map("storage_location_id")
  locationNote      String?             @db.VarChar(255) @map("location_note")
  isChecked         Boolean             @default(false) @map("is_checked")
  disposition       PackingDisposition?
  orderIndex        Int                 @default(0) @map("order_index")
  notes             String?             @db.Text

  checkedById Int?      @map("checked_by_id")
  checkedAt   DateTime? @map("checked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  productVariant  ProductVariant   @relation(fields: [productVariantId], references: [id])
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  checkedBy       Worker?          @relation("PackingCheckedBy", fields: [checkedById], references: [id], onDelete: SetNull)
  rabItems        RabItem[]        @relation("PackingSourcedRabItems")

  @@index([eventId, isChecked])
  @@index([productVariantId])
  @@map("event_packing_items")
}

// ----- CRM / Lead Pipeline ----- //

enum LeadLevel {
  HOT
  WARM
  COLD
  UNQUALIFIED
}

enum LeadSource {
  META_ADS         // Meta Ads (gabungan FB+IG dari Meta Business)
  INSTAGRAM_ADS    // Instagram Ads spesifik
  FACEBOOK_ADS     // Facebook Ads spesifik
  TIKTOK           // TikTok / TikTok Ads / Live Shopping
  LINKEDIN         // LinkedIn (B2B)
  WHATSAPP         // WhatsApp langsung
  WEBSITE          // Form website
  REFERRAL         // Referensi/rekomendasi
  WALK_IN          // Datang langsung ke kantor/toko
  EXHIBITION       // Pameran / Trade Expo / Booth event
  OTHER            // Lainnya — pakai sourceDetail untuk specifics
}

enum LeadStatus {
  NEW
  CONTACTED
  RESPONDED
  NO_RESPONSE
  WAITING            // menunggu (umum)
  WAITING_DECISION   // menunggu keputusan klien (setelah penawaran/proposal)
  PROPOSAL_SENT      // penawaran/SPH/quotation sudah dikirim
  NEGOTIATION        // sedang negosiasi (harga, scope, term)
  IN_PROGRESS        // sedang dikerjakan
  ON_HOLD            // di-pause sementara (klien minta tunggu, dll)
  CLOSED_DEAL
  CLOSED_LOST
}

model LeadStage {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(80)
  color      String  @default("#94a3b8") @db.VarChar(20)
  orderIndex Int     @default(0) @map("order_index")
  isTerminal Boolean @default(false) @map("is_terminal")
  isWinStage Boolean @default(false) @map("is_win_stage")

  leads Lead[]

  @@map("lead_stages")
}

model LeadLabel {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(60)
  color String @default("#ef4444") @db.VarChar(20)

  leads LeadLabelOnLead[]

  @@map("lead_labels")
}

model Lead {
  id                  Int         @id @default(autoincrement())
  name                String?     @db.VarChar(150)
  phone               String      @db.VarChar(50)
  phoneNormalized     String      @map("phone_normalized") @db.VarChar(30)
  organization        String?     @db.VarChar(200)
  productCategory     String?     @map("product_category") @db.VarChar(100)
  brand               EventBrand?
  level               LeadLevel?
  source              LeadSource @default(OTHER)
  sourceDetail        String?    @map("source_detail") @db.VarChar(150)
  greetingTemplate    String?    @map("greeting_template") @db.Text
  status              LeadStatus @default(NEW)
  stageId             Int        @map("stage_id")
  stageOrderIndex     Int        @default(0) @map("stage_order_index")
  assignedWorkerId    Int?       @map("assigned_worker_id")
  previousAssignedWorkerId Int?  @map("previous_assigned_worker_id")
  followUpDate        DateTime?  @map("follow_up_date")
  orderDescription    String?    @map("order_description") @db.Text
  projectValueEst     Decimal?   @map("project_value_est") @db.Decimal(15, 2)
  eventDateStart      DateTime?  @map("event_date_start")
  eventDateEnd        DateTime?  @map("event_date_end")
  eventLocation       String?    @map("event_location") @db.VarChar(200)
  /// Array event tambahan (multi-kota/multi-tanggal) — JSON: [{ name, location, dateStart, dateEnd }]
  /// Event utama tetap pakai eventDateStart/End/Location di atas. Field ini untuk event 2, 3, dst.
  additionalEvents    Json?      @map("additional_events")
  city                String?    @db.VarChar(100)
  notes               String?    @db.Text
  imageUrl            String?    @map("image_url") @db.Text  // Foto referensi/sketsa project lead (single image)
  leadCameAt          DateTime   @default(now()) @map("lead_came_at")
  lastContactedAt     DateTime?  @map("last_contacted_at")
  convertedCustomerId Int?       @unique @map("converted_customer_id")
  convertedAt         DateTime?  @map("converted_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  stage             LeadStage         @relation(fields: [stageId], references: [id])
  assignedWorker    Worker?           @relation("LeadAssignedWorker", fields: [assignedWorkerId], references: [id])
  previousAssignedWorker Worker?      @relation("LeadPreviousWorker", fields: [previousAssignedWorkerId], references: [id])
  convertedCustomer Customer?         @relation(fields: [convertedCustomerId], references: [id])
  labels            LeadLabelOnLead[]
  activities        LeadActivity[]

  @@index([stageId, stageOrderIndex])
  @@index([phoneNormalized])
  @@index([assignedWorkerId, status])
  @@index([leadCameAt])
  @@index([city])
  @@index([productCategory])
  @@index([brand])
  @@map("leads")
}

model LeadLabelOnLead {
  leadId  Int @map("lead_id")
  labelId Int @map("label_id")

  lead  Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  label LeadLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([leadId, labelId])
  @@map("lead_label_on_lead")
}

model LeadActivity {
  id        Int      @id @default(autoincrement())
  leadId    Int      @map("lead_id")
  kind      String   @db.VarChar(40)
  text      String?  @db.Text
  meta      Json?
  workerId  Int?     @map("worker_id")
  createdAt DateTime @default(now()) @map("created_at")

  lead   Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  worker Worker? @relation(fields: [workerId], references: [id])

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

/// Profil per-brand untuk surat penawaran multi-tenant.
/// Tidak menggantikan StoreSettings (yang tetap untuk global flags & fallback).
model BrandSettings {
  id                   Int        @id @default(autoincrement())
  brand                EventBrand @unique
  companyName          String     @map("company_name") @db.VarChar(200) // "CV. Exindo Pratama"
  companyCode          String     @map("company_code") @db.VarChar(20)  // "Ep" / "Xp" — dipakai di nomor seri
  directorName         String?    @map("director_name") @db.VarChar(150)
  logoImageUrl         String?    @map("logo_image_url") @db.Text       // logo kecil di pojok
  letterheadImageUrl   String?    @map("letterhead_image_url") @db.Text // kop surat full-page background image
  stampImageUrl        String?    @map("stamp_image_url") @db.Text       // stempel default brand (fallback kalau worker tidak punya stempel pribadi)
  address              String?    @db.Text
  phone                String?    @db.VarChar(50)
  email                String?    @db.VarChar(150)
  npwp                 String?    @db.VarChar(50)
  bankAccountIds       String?    @map("bank_account_ids") @db.VarChar(200) // CSV BankAccount.id default
  letterheadFooter     String?    @map("letterhead_footer") @db.Text   // kept for backward-compat
  quotationDisclaimer  String?    @map("quotation_disclaimer") @db.Text // "# Harga belum termasuk..."
  quotationPaymentTerms String?   @map("quotation_payment_terms") @db.Text // "Sedangkan system pembayaran 50%..."
  quotationClosing     String?    @map("quotation_closing") @db.Text   // "Demikian penawaran kerjasama kami..."
  invoiceClosingText   String?    @map("invoice_closing_text") @db.Text // "Nb: Jika terjadi pembatalan..." khusus untuk invoice (bukan penawaran)
  openingTemplate      String?    @map("opening_template") @db.Text     // Template paragraf "Dengan hormat..." — bisa di-copy ke quotation
  // English versions — dipakai kalau quotation.language = 'en'
  quotationDisclaimerEn   String? @map("quotation_disclaimer_en") @db.Text
  quotationPaymentTermsEn String? @map("quotation_payment_terms_en") @db.Text
  quotationClosingEn      String? @map("quotation_closing_en") @db.Text
  invoiceClosingTextEn    String? @map("invoice_closing_text_en") @db.Text
  openingTemplateEn       String? @map("opening_template_en") @db.Text
  themeColor           String?    @map("theme_color") @db.VarChar(20) // Hex color untuk PDF header & accent (mis. "#1e40af"). Null = pakai default per brand.
  /// Custom labels untuk opening paragraph invoice — JSON object.
  /// Setiap key bisa di-override; kalau null/empty → pakai default.
  /// Keys yang di-support:
  ///   dp, pelunasan, full, verbSewa, verbPengadaan, untukEvent, padaTanggal, di, rincianSuffix
  /// Contoh: {"dp":"Uang Muka","pelunasan":"Pelunasan","verbSewa":"Penyewaan"}
  invoiceLabelOverrides Json? @map("invoice_label_overrides")
  isActive             Boolean    @default(true) @map("is_active")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  @@map("brand_settings")
}

/// Konfigurasi varian penawaran (CRUD-able). Dipakai sebagai sumber dropdown
/// di /penawaran create form, juga menentukan template & format surat.
/// Auto-seed 2 default (SEWA, PENGADAAN_BOOTH) saat pertama kali list.
model QuotationVariantConfig {
  id                  Int      @id @default(autoincrement())
  code                String   @unique @db.VarChar(50)   // mis. "SEWA", "INTERIOR", "JASA_DESAIN"
  label               String   @db.VarChar(150)          // mis. "Sewa Perlengkapan Event"
  subject             String?  @db.VarChar(200)          // override subject surat — kalau null pakai label
  templateKey         String   @default("pengadaan-booth") @map("template_key") @db.VarChar(50) // "sewa" | "pengadaan-booth"
  defaultDpPercent    Decimal  @default(50) @map("default_dp_percent") @db.Decimal(5, 2)
  color               String?  @db.VarChar(20)           // mis. "#c8203a" untuk badge
  description         String?  @db.Text                  // hint untuk user di dropdown
  orderIndex          Int      @default(0) @map("order_index")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("quotation_variant_configs")
}

/// Pengadaan inventaris dari RAB.
/// Setiap RabItem dengan isInventory=true otomatis spawn 1 record ini saat RAB save.
/// Admin bisa store ke stok (create stock movement + link ProductVariant) atau cancel.
model InventoryAcquisition {
  id                Int       @id @default(autoincrement())
  rabPlanId         Int       @map("rab_plan_id")
  rabItemId         Int       @unique @map("rab_item_id")  // 1:1 dengan RabItem
  description       String    @db.VarChar(255)             // snapshot dari RabItem.description
  quantity          Decimal   @db.Decimal(15, 4)
  unit              String?   @db.VarChar(50)
  unitCost          Decimal   @map("unit_cost") @db.Decimal(15, 2)
  totalCost         Decimal   @map("total_cost") @db.Decimal(15, 2)
  status            String    @default("PENDING") @db.VarChar(20) // PENDING | STORED | CANCELLED
  productVariantId  Int?      @map("product_variant_id")          // kalau di-stok, link ke variant existing/new
  warehouseId       Int?      @map("warehouse_id")                // gudang destination
  storedAt          DateTime? @map("stored_at")
  photoUrl          String?   @map("photo_url") @db.Text          // foto barang fisik untuk audit
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  rabPlan        RabPlan         @relation("RabPlanAcquisitions", fields: [rabPlanId], references: [id], onDelete: Cascade)
  rabItem        RabItem         @relation("RabItemAcquisition", fields: [rabItemId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation("VariantAcquisitions", fields: [productVariantId], references: [id], onDelete: SetNull)
  warehouse      Warehouse?      @relation("WarehouseAcquisitions", fields: [warehouseId], references: [id], onDelete: SetNull)

  @@index([rabPlanId])
  @@index([status])
  @@map("inventory_acquisitions")
}
