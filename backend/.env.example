# Database (MySQL)
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/pospro"

# Auth
JWT_SECRET="your_long_random_secret_here"

# Server
PORT=3001

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3000"

# WhatsApp Bot (opsional)
# Bot dimatikan secara default untuk menghemat resource (Puppeteer/Chromium headless).
# Set ke "true" untuk mengaktifkan kembali. (Rencana: diganti webhook Discord.)
WHATSAPP_ENABLED="false"
WHATSAPP_REPORT_GROUP_ID=""
