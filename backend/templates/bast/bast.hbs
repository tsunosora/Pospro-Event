<!doctype html>
<html lang="id">
<head>
<meta charset="utf-8" />
<title>BAST {{doc.number}}</title>
<style>
  @page { size: A4; margin: 0; }
  * { box-sizing: border-box; }
  html, body { margin:0; padding:0; font-family:'Calibri','Arial',sans-serif; font-size:11pt; color:#111; line-height:1.5; }
  .letterhead-bg { position:fixed; top:0; left:0; width:210mm; height:297mm; z-index:-1; pointer-events:none; user-select:none; }
  table.page-layout { width:100%; border-collapse:collapse; }
  table.page-layout > thead > tr > td.page-header-spacer { height: {{#if company.letterheadUrl}}38mm{{else}}18mm{{/if}}; padding:0; border:0; }
  table.page-layout > tfoot > tr > td.page-footer-spacer { height: {{#if company.letterheadUrl}}45mm{{else}}22mm{{/if}}; padding:0; border:0; }
  table.page-layout > tbody > tr > td.page-content { padding:0 22mm; vertical-align:top; }
  .fallback-header { display:flex; align-items:flex-start; gap:12pt; border-bottom:2pt solid {{theme.primary}}; padding-bottom:8pt; margin-bottom:14pt; }
  .fallback-header .logo { width:60pt; height:60pt; object-fit:contain; }
  .fallback-header .company-name { font-weight:700; font-size:16pt; color:{{theme.primary}}; letter-spacing:.5pt; }
  .fallback-header .company-addr { font-size:9.5pt; color:#333; margin-top:2pt; line-height:1.35; }
  .doc-title { text-align:center; font-size:14pt; font-weight:800; text-decoration:underline; letter-spacing:1pt; margin:6pt 0 2pt 0; text-transform:uppercase; }
  .doc-sub { text-align:center; font-size:10.5pt; color:#444; margin-bottom:14pt; }
  table.meta { font-size:11pt; line-height:1.55; margin-bottom:12pt; }
  table.meta td { padding:1pt 0; vertical-align:top; }
  table.meta td.k { width:160pt; font-weight:600; }
  table.meta td.s { width:12pt; }
  .intro { text-align:justify; line-height:1.6; margin:8pt 0; }
  table.items { width:100%; border-collapse:collapse; margin:8pt 0 12pt 0; font-size:11pt; line-height:1.5; }
  table.items th, table.items td { border:0.75pt solid #999; padding:4pt 6pt; }
  table.items thead { background:{{theme.primary}}; color:#fff; }
  table.items th { font-weight:600; text-align:center; }
  table.items td.num { text-align:center; width:28pt; }
  table.items td.qty { text-align:center; white-space:nowrap; width:90pt; }
  table.items tr.cat-header td { background:{{theme.primaryLight}}; color:{{theme.primaryDark}}; font-weight:700; font-size:10.5pt; text-transform:uppercase; letter-spacing:.3pt; padding:5pt 8pt; }
  .statement { text-align:justify; line-height:1.6; margin:10pt 0; }
  .notes-block { margin:8pt 0; padding:6pt 10pt; border-left:3pt solid {{theme.primary}}; background:{{theme.primarySubtle}}; line-height:1.55; white-space:pre-line; }
  .sign-date { margin-top:16pt; font-weight:600; }
  .signature-row { display:flex; justify-content:space-between; gap:30pt; margin-top:12pt; page-break-inside:avoid; }
  .signature-row .block { flex:1; text-align:center; min-width:200pt; }
  .signature-row .role { font-weight:700; margin-bottom:4pt; }
  .signature-row .sign-area { position:relative; height:80pt; margin:4pt 0; }
  .signature-row .sign-image { position:absolute; top:0; left:50%; transform:translateX(-50%); max-height:80pt; max-width:180pt; z-index:2; }
  .signature-row .stamp-image { position:absolute; top:8pt; left:50%; transform:translateX(-72%); max-height:80pt; max-width:110pt; opacity:.85; z-index:1; mix-blend-mode:multiply; }
  .signature-row .materai { font-size:10pt; font-style:italic; color:#555; padding:26pt 0; }
  .signature-row .name { font-weight:700; text-decoration:underline; margin-top:4pt; }
  .end-spacer { height:36pt; }
</style>
</head>
<body>
{{#if company.letterheadUrl}}<img class="letterhead-bg" src="{{company.letterheadUrl}}" alt="" />{{/if}}
<table class="page-layout">
  <thead><tr><td class="page-header-spacer"></td></tr></thead>
  <tfoot><tr><td class="page-footer-spacer"></td></tr></tfoot>
  <tbody><tr><td class="page-content">

  {{#unless company.letterheadUrl}}
  <div class="fallback-header">
    {{#if company.logoUrl}}<img class="logo" src="{{company.logoUrl}}" />{{/if}}
    <div>
      <div class="company-name">{{company.name}}</div>
      <div class="company-addr">{{company.address}}<br/>{{#if company.phone}}Telp {{company.phone}}{{/if}}{{#if company.email}} &bull; {{company.email}}{{/if}}</div>
    </div>
  </div>
  {{/unless}}

  <div class="doc-title">Berita Acara Serah Terima</div>
  <div class="doc-sub">Nomor: {{doc.number}}</div>

  <p class="intro">Pada hari ini, {{doc.dateFormatted}}, yang bertanda tangan di bawah ini telah melakukan serah terima atas pekerjaan/hasil sebagaimana diuraikan di bawah:</p>

  <table class="meta">
    <tr><td class="k">Nama Kegiatan / Event</td><td class="s">:</td><td>{{project.name}}</td></tr>
    {{#if project.location}}<tr><td class="k">Lokasi</td><td class="s">:</td><td>{{project.location}}</td></tr>{{/if}}
    {{#if project.dateRange}}<tr><td class="k">Tanggal Pelaksanaan</td><td class="s">:</td><td>{{project.dateRange}}</td></tr>{{/if}}
    <tr><td class="k">Pihak Pertama (Vendor)</td><td class="s">:</td><td>{{vendor.name}}{{#if vendor.signerName}} — {{vendor.signerName}}{{/if}}</td></tr>
    <tr><td class="k">Pihak Kedua (Penerima)</td><td class="s">:</td><td>{{receiver.name}}{{#if receiver.position}} — {{receiver.position}}{{/if}}{{#if receiver.company}} ({{receiver.company}}){{/if}}</td></tr>
  </table>

  {{#if items.length}}
  <table class="items">
    <thead><tr><th style="width:28pt">No</th><th>Uraian</th><th style="width:90pt">Qty</th><th style="width:120pt">Keterangan</th></tr></thead>
    <tbody>
      {{#each itemGroups}}
        {{#if this.categoryName}}<tr class="cat-header"><td colspan="4">{{this.categoryName}}</td></tr>{{/if}}
        {{#each this.items}}
        <tr>
          <td class="num">{{this.no}}</td>
          <td>{{this.description}}</td>
          <td class="qty">{{this.quantity}}</td>
          <td>{{this.note}}</td>
        </tr>
        {{/each}}
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  <p class="statement">Pihak Pertama menyatakan telah menyelesaikan dan menyerahkan seluruh pekerjaan/hasil di atas dalam kondisi baik dan lengkap. Pihak Kedua menyatakan telah menerima penyerahan tersebut dengan baik. Demikian Berita Acara Serah Terima ini dibuat untuk dipergunakan sebagaimana mestinya.</p>

  {{#if doc.notes}}<div class="notes-block">{{doc.notes}}</div>{{/if}}

  <div class="sign-date">{{doc.dateFormatted}}</div>

  <div class="signature-row">
    <div class="block">
      <div class="role">Pihak Pertama<br/>{{vendor.name}}</div>
      <div class="sign-area">
        {{#if vendor.stampUrl}}<img class="stamp-image" src="{{vendor.stampUrl}}" alt="Stempel" />{{/if}}
        {{#if vendor.signatureUrl}}<img class="sign-image" src="{{vendor.signatureUrl}}" alt="Tanda Tangan" />{{/if}}
      </div>
      <div class="name">{{vendor.signerName}}</div>
    </div>
    <div class="block">
      <div class="role">Pihak Kedua<br/>{{#if receiver.company}}{{receiver.company}}{{else}}Penerima{{/if}}</div>
      <div class="sign-area"><div class="materai">Materai</div></div>
      <div class="name">{{receiver.name}}</div>
    </div>
  </div>

  <div class="end-spacer"></div>
  </td></tr></tbody>
</table>
</body>
</html>
