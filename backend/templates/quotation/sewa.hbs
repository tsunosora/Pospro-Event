<!doctype html>
<html lang="id">
<head>
<meta charset="utf-8" />
<title>Penawaran {{doc.number}}</title>
<style>
  @page { size: A4; margin: 15mm 18mm 18mm 18mm; }
  * { box-sizing: border-box; }
  body { font-family: 'Calibri', 'Arial', sans-serif; font-size: 11pt; color: #111; }
  .header { display: flex; align-items: flex-start; gap: 12pt; border-bottom: 2pt solid #1a3b7c; padding-bottom: 8pt; }
  .header .logo { width: 60pt; height: 60pt; object-fit: contain; }
  .header .company-name { font-weight: 700; font-size: 16pt; color: #1a3b7c; letter-spacing: .5pt; }
  .header .company-addr { font-size: 9.5pt; color: #333; margin-top: 2pt; line-height: 1.35; }
  .doc-meta { margin-top: 14pt; display: flex; justify-content: space-between; align-items: flex-start; }
  .doc-meta .nomor { font-size: 11pt; }
  .doc-meta .nomor strong { display: inline-block; min-width: 50pt; }
  .doc-meta .kota-tgl { text-align: right; }
  .kepada { margin-top: 12pt; }
  .kepada .label { font-weight: 600; }
  .perihal { margin-top: 8pt; font-weight: 700; text-decoration: underline; }
  .opening { margin-top: 10pt; text-align: justify; line-height: 1.5; }
  .event-info { margin-top: 8pt; font-size: 10.5pt; }
  .event-info td { padding: 1pt 4pt 1pt 0; vertical-align: top; }
  .event-info td:first-child { width: 90pt; color: #555; }
  table.items { width: 100%; border-collapse: collapse; margin-top: 12pt; font-size: 10.5pt; }
  table.items th, table.items td { border: 1pt solid #666; padding: 4pt 6pt; }
  table.items thead { background: #1a3b7c; color: #fff; }
  table.items th { font-weight: 600; text-align: center; }
  table.items td.num { text-align: center; width: 28pt; }
  table.items td.qty { text-align: right; white-space: nowrap; }
  table.items td.rp { text-align: right; white-space: nowrap; }
  table.items tfoot td { font-weight: 600; }
  table.items tfoot td.label { text-align: right; }
  .grand-total td { background: #f1f5fb; }
  .terbilang { margin-top: 8pt; font-style: italic; font-size: 10.5pt; }
  .terms { margin-top: 12pt; }
  .terms h4 { font-size: 11pt; margin: 0 0 4pt 0; color: #1a3b7c; }
  .terms ol { padding-left: 18pt; margin: 0; line-height: 1.5; font-size: 10pt; }
  .bank-list { margin-top: 6pt; font-size: 10pt; }
  .bank-list li { margin-bottom: 2pt; }
  .signature { margin-top: 24pt; display: flex; justify-content: flex-end; }
  .signature .block { text-align: center; min-width: 180pt; }
  .signature .role { margin-bottom: 60pt; }
  .signature .director { font-weight: 700; text-decoration: underline; }
  .footer-note { margin-top: 18pt; font-size: 9pt; color: #555; border-top: 1pt dashed #999; padding-top: 6pt; }
  .badge-rev { display: inline-block; background: #d93737; color: #fff; padding: 1pt 6pt; border-radius: 3pt; font-size: 9pt; margin-left: 6pt; }
</style>
</head>
<body>

<div class="header">
  {{#if company.logoUrl}}<img class="logo" src="{{company.logoUrl}}" />{{/if}}
  <div>
    <div class="company-name">{{company.name}}</div>
    <div class="company-addr">
      {{company.address}}<br/>
      {{#if company.phone}}Telp: {{company.phone}}{{/if}}{{#if company.email}} &bull; {{company.email}}{{/if}}
    </div>
  </div>
</div>

<div class="doc-meta">
  <div class="nomor">
    <div><strong>Nomor</strong>: {{doc.number}}{{#if doc.isRevision}}<span class="badge-rev">Rev. {{doc.revisionNumber}}</span>{{/if}}</div>
    <div><strong>Lampiran</strong>: 1 (satu) berkas</div>
    <div><strong>Perihal</strong>: {{doc.subject}}</div>
  </div>
  <div class="kota-tgl">
    {{doc.city}}, {{doc.dateFormatted}}
  </div>
</div>

<div class="kepada">
  <div class="label">Kepada Yth.,</div>
  <div>{{client.name}}</div>
  {{#if client.company}}<div><strong>{{client.company}}</strong></div>{{/if}}
  {{#if client.address}}<div>{{client.address}}</div>{{/if}}
  <div>di Tempat</div>
</div>

<p class="opening">
  Dengan hormat,<br/>
  Bersama surat ini kami {{company.name}} mengajukan penawaran harga <strong>{{doc.variantLabel}}</strong>
  {{#if project.name}}untuk acara <strong>{{project.name}}</strong>{{/if}}
  {{#if project.location}} di <strong>{{project.location}}</strong>{{/if}}
  {{#if project.dateRange}} pada tanggal <strong>{{project.dateRange}}</strong>{{/if}}.
  Adapun rincian penawaran kami adalah sebagai berikut:
</p>

<table class="items">
  <thead>
    <tr>
      <th style="width:28pt">No</th>
      <th>Uraian</th>
      <th style="width:72pt">Qty</th>
      <th style="width:90pt">Harga Satuan</th>
      <th style="width:100pt">Jumlah</th>
    </tr>
  </thead>
  <tbody>
    {{#each items}}
    <tr>
      <td class="num">{{this.no}}</td>
      <td>{{this.description}}</td>
      <td class="qty">{{this.quantity}}</td>
      <td class="rp">{{this.price}}</td>
      <td class="rp">{{this.subtotal}}</td>
    </tr>
    {{/each}}
  </tbody>
  <tfoot>
    <tr>
      <td colspan="4" class="label">Subtotal</td>
      <td class="rp">{{totals.subtotal}}</td>
    </tr>
    {{#if totals.discount}}
    <tr>
      <td colspan="4" class="label">Diskon</td>
      <td class="rp">({{totals.discount}})</td>
    </tr>
    {{/if}}
    <tr>
      <td colspan="4" class="label">PPN {{totals.taxRate}}%</td>
      <td class="rp">{{totals.taxAmount}}</td>
    </tr>
    <tr class="grand-total">
      <td colspan="4" class="label">Grand Total</td>
      <td class="rp">{{totals.total}}</td>
    </tr>
  </tfoot>
</table>

<div class="terbilang">Terbilang: <strong>{{totals.totalTerbilang}}</strong></div>

<div class="terms">
  <h4>Syarat &amp; Ketentuan</h4>
  <ol>
    <li>Penawaran berlaku hingga {{#if doc.validUntilFormatted}}{{doc.validUntilFormatted}}{{else}}14 hari sejak tanggal penawaran{{/if}}.</li>
    <li>Harga sudah termasuk PPN {{totals.taxRate}}%.</li>
    <li>Pembayaran: DP {{payment.dpPercent}}% ({{payment.dpAmount}}) sebelum pemasangan, pelunasan {{payment.pelunasan}} setelah acara selesai.</li>
    <li>Harga belum termasuk biaya transportasi ke luar kota (apabila ada).</li>
    {{#if notes}}<li>{{notes}}</li>{{/if}}
  </ol>

  {{#if payment.banks.length}}
  <h4 style="margin-top:10pt">Pembayaran Transfer Ke:</h4>
  <ul class="bank-list">
    {{#each payment.banks}}
    <li>Bank <strong>{{this.bankName}}</strong> — No. Rek. <strong>{{this.accountNumber}}</strong> a.n. {{this.accountOwner}}</li>
    {{/each}}
  </ul>
  {{/if}}
</div>

<div class="signature">
  <div class="block">
    <div class="role">Hormat kami,<br/>{{company.name}}</div>
    <div class="director">{{company.directorName}}</div>
    <div>Direktur</div>
  </div>
</div>

<div class="footer-note">
  Demikian penawaran ini kami sampaikan. Atas perhatian dan kerjasamanya kami ucapkan terima kasih.
</div>

</body>
</html>
