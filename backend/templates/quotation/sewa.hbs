<!doctype html>
<html lang="id">
<head>
<meta charset="utf-8" />
<title>Penawaran {{doc.number}}</title>
<style>
  /* STRATEGI:
     - @page { margin: 0 } → paper full bleed, image fixed bisa full 210×297mm tanpa clip
     - <table class="page-layout"> dengan <thead>/<tfoot> spacer → memberi margin atas/bawah PER PAGE
       (CSS Paged Media: <thead> dan <tfoot> tabel otomatis ter-repeat saat tabel split antar halaman)
     - .letterhead-bg position:fixed full A4 → repeat di setiap halaman saat print Chromium */
  @page {
    size: A4;
    margin: 0;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    padding: 0;
    font-family: 'Calibri', 'Arial', sans-serif;
    font-size: 11pt;
    color: #111;
    line-height: 1.45;
  }

  /* Letterhead — full A4 paper, posisi 0,0 (karena @page margin = 0). Repeat di setiap page. */
  {{#if company.letterheadUrl}}
  .letterhead-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 210mm;
    height: 297mm;
    z-index: -1;
    pointer-events: none;
    user-select: none;
  }
  {{/if}}

  /* Table layout untuk per-page header/footer spacer.
     <thead> & <tfoot> di tabel akan AUTO-REPEAT di setiap halaman saat content overflow. */
  table.page-layout {
    width: 100%;
    border-collapse: collapse;
  }
  table.page-layout > thead > tr > td.page-header-spacer {
    height: {{#if company.letterheadUrl}}38mm{{else}}18mm{{/if}};
    padding: 0;
    border: 0;
  }
  table.page-layout > tfoot > tr > td.page-footer-spacer {
    height: {{#if company.letterheadUrl}}45mm{{else}}22mm{{/if}};
    padding: 0;
    border: 0;
  }
  table.page-layout > tbody > tr > td.page-content {
    padding: 0 22mm;
    vertical-align: top;
  }

  /* Fallback header (kalau tidak ada letterhead) */
  .fallback-header {
    display: flex; align-items: flex-start; gap: 12pt;
    border-bottom: 2pt solid {{theme.primary}};
    padding-bottom: 8pt;
    margin-bottom: 14pt;
  }
  .fallback-header .logo { width: 60pt; height: 60pt; object-fit: contain; }
  .fallback-header .company-name { font-weight: 700; font-size: 16pt; color: {{theme.primary}}; letter-spacing: .5pt; }
  .fallback-header .company-addr { font-size: 9.5pt; color: #333; margin-top: 2pt; line-height: 1.35; }

  .doc-meta { margin-bottom: 10pt; }
  .doc-meta .nomor { font-size: 11pt; line-height: 1.55; }
  .doc-meta .nomor strong { display: inline-block; min-width: 65pt; }
  .kota-tgl-top { font-size: 11pt; margin-bottom: 6pt; line-height: 1.55; }
  .kota-tgl-top strong { display: inline-block; min-width: 65pt; }

  .kepada { margin-bottom: 8pt; line-height: 1.45; }
  .kepada .label { font-weight: 600; }

  .opening { margin-top: 10pt; text-align: justify; line-height: 1.5; }

  table.items {
    width: 100%; border-collapse: collapse;
    margin-top: 12pt; font-size: 10.5pt;
  }
  table.items th, table.items td { border: 0.75pt solid #999; padding: 4pt 6pt; }
  table.items thead { background: {{theme.primary}}; color: #fff; }
  table.items th { font-weight: 600; text-align: center; }
  table.items td.num { text-align: center; width: 28pt; }
  table.items td.qty { text-align: right; white-space: nowrap; }
  table.items td.rp { text-align: right; white-space: nowrap; }
  /* Header kategori — baris tebal warna untuk grouping */
  table.items tr.cat-header td {
    background: {{theme.primaryLight}};
    font-weight: 700;
    color: {{theme.primaryDark}};
    text-transform: uppercase;
    font-size: 10pt;
    letter-spacing: .3pt;
  }
  table.items tr.cat-subtotal td {
    background: {{theme.primarySubtle}};
    font-weight: 600;
    font-style: italic;
    font-size: 10pt;
  }
  table.items tfoot td { font-weight: 600; }
  table.items tfoot td.label { text-align: right; }
  /* Grand total block — tampil sekali di akhir tabel (BUKAN tfoot supaya tidak ter-repeat per halaman) */
  table.items tbody.grand-totals td { font-weight: 600; }
  table.items tbody.grand-totals td.label { text-align: right; }
  table.items tbody.grand-totals { page-break-inside: avoid; }
  .grand-total td { background: #f1f5fb; }

  .terbilang { margin-top: 8pt; font-style: italic; font-size: 10.5pt; }

  /* Custom text section — rapikan dengan section header & spacing konsisten */
  .text-section { margin-top: 12pt; }
  .text-section .section-title {
    font-weight: 700;
    font-size: 11pt;
    color: {{theme.primary}};
    margin-bottom: 4pt;
    border-bottom: 0.5pt solid {{theme.primary}};
    padding-bottom: 2pt;
  }
  .text-body {
    line-height: 1.55;
    text-align: justify;
    font-size: 10.5pt;
    white-space: pre-line;
    margin: 0;
  }
  .text-body.disclaimer { font-size: 10pt; color: #333; }

  .bank-list { margin-top: 4pt; font-size: 10pt; padding-left: 18pt; }
  .bank-list li { margin-bottom: 2pt; }

  .closing-section { margin-top: 12pt; }
  .closing-text {
    line-height: 1.55;
    text-align: justify;
    font-size: 10.5pt;
    white-space: pre-line;
  }

  .signature { margin-top: 22pt; display: flex; justify-content: flex-end; page-break-inside: avoid; }
  .signature .block {
    text-align: center;
    min-width: 220pt;
    position: relative;
  }
  .signature .role { line-height: 1.4; margin-bottom: 4pt; }
  .signature .sign-area {
    position: relative;
    height: 80pt;
    margin-top: 4pt;
    margin-bottom: 4pt;
  }
  .signature .sign-image {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    max-height: 80pt;
    max-width: 180pt;
    z-index: 2;
  }
  .signature .stamp-image {
    position: absolute;
    top: 8pt;
    left: 50%;
    transform: translateX(-72%);
    max-height: 80pt;
    max-width: 110pt;
    opacity: 0.85;          /* stempel sedikit transparan biar nama tetap kebaca */
    z-index: 1;
    mix-blend-mode: multiply; /* warna stempel menyatu dengan kertas */
  }
  .signature .director {
    font-weight: 700;
    text-decoration: underline;
  }
  .signature .position-label {
    font-size: 10pt;
    color: #444;
    margin-top: 2pt;
  }

  /* Jaga jarak bawah agar text tidak mepet ke footer kop surat */
  .closing-section { margin-top: 16pt; margin-bottom: 16pt; }
  .end-spacer { height: 36pt; }
  .text-section { margin-bottom: 8pt; }
  .signature { padding-bottom: 12pt; }

  /* Hindari pemotongan section di antara halaman */
  .text-section, table.items thead, table.items tbody.grand-totals { page-break-inside: avoid; }

  .badge-rev { display: inline-block; background: #d93737; color: #fff; padding: 1pt 6pt; border-radius: 3pt; font-size: 9pt; margin-left: 6pt; }
</style>
</head>
<body>

{{#if company.letterheadUrl}}
<img class="letterhead-bg" src="{{company.letterheadUrl}}" alt="" />
{{/if}}

<table class="page-layout">
  <thead>
    <tr><td class="page-header-spacer"></td></tr>
  </thead>
  <tfoot>
    <tr><td class="page-footer-spacer"></td></tr>
  </tfoot>
  <tbody>
    <tr><td class="page-content">

<div class="content">

    {{#unless company.letterheadUrl}}
    <div class="fallback-header">
      {{#if company.logoUrl}}<img class="logo" src="{{company.logoUrl}}" />{{/if}}
      <div>
        <div class="company-name">{{company.name}}</div>
        <div class="company-addr">
          {{company.address}}<br/>
          {{#if company.phone}}Telp: {{company.phone}}{{/if}}{{#if company.email}} &bull; {{company.email}}{{/if}}
        </div>
      </div>
    </div>
    {{/unless}}

    {{#if doc.isInvoice}}
    <div style="text-align:center; padding:8pt 0; margin-bottom: 6pt; border-bottom: 2pt solid {{theme.primary}};">
      <div style="font-size: 18pt; font-weight: 800; color: {{theme.primary}}; letter-spacing: 1pt;">{{doc.invoicePartLabel}}</div>
    </div>
    {{/if}}

    {{!-- Kota & Tanggal di ATAS nomor, rata kiri. Kalau city kosong, tampilkan tanggal saja. --}}
    <div class="kota-tgl-top">
      <strong>{{i18n.tanggal}}</strong>: {{#if doc.city}}{{doc.city}}, {{/if}}{{doc.dateFormatted}}
    </div>
    <div class="doc-meta">
      <div class="nomor">
        <div><strong>{{#if doc.isInvoice}}{{i18n.noInvoice}}{{else}}{{i18n.nomor}}{{/if}}</strong>: {{doc.number}}</div>
        {{#unless doc.isInvoice}}<div style="white-space: pre-line;"><strong>{{i18n.lampiran}}</strong>: {{attachment.label}}</div>{{/unless}}
        <div><strong>{{i18n.perihal}}</strong>: <u><strong>{{doc.subject}}</strong></u></div>
        {{#if doc.dueDateFormatted}}
        <div><strong>Jatuh Tempo</strong>: <span style="color:{{theme.primary}}; font-weight:700">{{doc.dueDateFormatted}}</span></div>
        {{/if}}
      </div>
    </div>

    <div class="kepada">
      <div class="label">{{i18n.kepada}}</div>
      {{#if client.company}}<div><strong>{{client.company}}</strong></div>{{/if}}
      <div>{{client.name}}</div>
      {{#if client.address}}<div>{{client.address}}</div>{{/if}}
    </div>

    {{#if customOpening}}
    {{!-- Custom opening per quotation — override default --}}
    <p class="opening" style="white-space: pre-line;">{{customOpening}}</p>
    {{else if doc.isInvoice}}
    <p class="opening">
      {{i18n.denganHormat}}<br/>
      {{i18n.bersamaInvoice}} <strong>{{company.name}}</strong> {{i18n.menagihkanPembayaran}}
      {{#eq doc.invoicePart "DP"}}<strong>{{i18n.uangMuka}}</strong>{{/eq}}
      {{#eq doc.invoicePart "PELUNASAN"}}<strong>{{i18n.pelunasan}}</strong>{{/eq}}
      {{i18n.atas}} <strong>{{doc.variantLabel}}</strong>
      {{#if hasMultipleEvents}} {{i18n.untukAcara}}{{#each events}} <strong>{{this.name}}</strong>{{#if this.location}} ({{this.location}}{{#if this.dateRange}}, {{this.dateRange}}{{/if}}){{else}}{{#if this.dateRange}} ({{this.dateRange}}){{/if}}{{/if}}{{#unless @last}};{{/unless}}{{/each}}.{{else}}{{#if project.name}} {{i18n.untukAcara}} <strong>{{project.name}}</strong>{{/if}}{{#if project.location}} {{i18n.di}} <strong>{{project.location}}</strong>{{/if}}{{#if project.dateRange}} {{i18n.padaTanggal}} <strong>{{project.dateRange}}</strong>{{/if}}.{{/if}}
      {{i18n.rincianTagihan}}
    </p>
    {{else}}
    <p class="opening">
      {{i18n.denganHormat}}<br/>
      {{i18n.bersamaSurat}} <strong>{{company.name}}</strong> {{i18n.mengajukanPenawaran}} <strong>{{doc.variantLabel}}</strong>
      {{#if hasMultipleEvents}} {{i18n.untukAcara}}{{#each events}} <strong>{{this.name}}</strong>{{#if this.location}} ({{this.location}}{{#if this.dateRange}}, {{this.dateRange}}{{/if}}){{else}}{{#if this.dateRange}} ({{this.dateRange}}){{/if}}{{/if}}{{#unless @last}};{{/unless}}{{/each}}.{{else}}{{#if project.name}} {{i18n.untukAcara}} <strong>{{project.name}}</strong>{{/if}}{{#if project.location}} {{i18n.di}} <strong>{{project.location}}</strong>{{/if}}{{#if project.dateRange}} {{i18n.padaTanggal}} <strong>{{project.dateRange}}</strong>{{/if}}.{{/if}}
      {{i18n.rincianPenawaran}}
    </p>
    {{/if}}

    {{#if doc.isEventGrouped}}
    {{!-- ============================================================
         MODE: EVENT-GROUPED — Items dipisah per event lokasi (PDF Nukahiji EO style)
         ============================================================ --}}
    <table class="items">
      <thead>
        <tr>
          <th style="width:28pt">{{i18n.no}}</th>
          <th>{{i18n.uraian}}</th>
          <th style="width:72pt">{{i18n.qty}}</th>
          <th style="width:90pt">{{i18n.hargaSatuan}}</th>
          <th style="width:100pt">{{i18n.jumlah}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each itemsByEvent}}
        <tr class="cat-header">
          <td colspan="5">{{this.no}}. {{this.eventName}}{{#if this.eventLocation}}, {{this.eventLocation}}{{/if}}{{#if this.eventDateRange}} — {{this.eventDateRange}}{{/if}}</td>
        </tr>
        {{#each this.items}}
        <tr>
          <td class="num">{{this.no}}</td>
          <td>{{this.description}}</td>
          <td class="qty">{{this.quantity}}</td>
          <td class="rp">{{this.price}}</td>
          <td class="rp">{{this.subtotal}}</td>
        </tr>
        {{/each}}
        <tr class="cat-subtotal">
          <td colspan="4" style="text-align:right">Subtotal {{this.eventName}}</td>
          <td class="rp">{{this.subtotalFormatted}}</td>
        </tr>
        {{/each}}
      </tbody>
      <tbody class="grand-totals">
        {{#if showGrandTotal}}
        <tr>
          <td colspan="4" class="label">Total Harga Penawaran</td>
          <td class="rp">{{totals.subtotal}}</td>
        </tr>
        {{#if totals.discount}}
        <tr>
          <td colspan="4" class="label">{{i18n.diskon}}</td>
          <td class="rp">({{totals.discount}})</td>
        </tr>
        {{/if}}
        {{#if totals.taxRate}}
        <tr>
          <td colspan="4" class="label">{{i18n.ppn}} {{totals.taxRate}}%</td>
          <td class="rp">{{totals.taxAmount}}</td>
        </tr>
        {{/if}}
        {{#if packagePriceFormatted}}
        <tr class="grand-total" style="background:{{theme.primarySubtle}};">
          <td colspan="4" class="label">Harga Paket</td>
          <td class="rp">{{packagePriceFormatted}}</td>
        </tr>
        {{else}}
        <tr class="grand-total">
          <td colspan="4" class="label">{{i18n.grandTotal}}</td>
          <td class="rp">{{totals.total}}</td>
        </tr>
        {{/if}}
        {{/if}}
      </tbody>
    </table>
    {{else if doc.isPackageMode}}
    {{!-- ============================================================
         MODE: PACKAGE — Per-package list dengan opsi harga + spec per package
         (PDF Jalakx style: Package 1/2/3 dengan ukuran options + spec list per paket)
         ============================================================ --}}
    <div class="package-container" style="margin-top: 12pt;">
      {{#each packages}}
      <div class="package-block" style="margin-bottom: 14pt;">
        <div class="package-name" style="font-size: 11.5pt; font-weight: 700; color: {{../theme.primary}}; padding: 4pt 8pt; background: {{../theme.primaryLight}}; border-left: 4pt solid {{../theme.primary}}; margin-bottom: 6pt;">
          {{this.no}}. {{this.name}}
        </div>
        {{!-- Pricing options --}}
        <ul class="package-options" style="margin: 0 0 4pt 24pt; padding: 0; list-style: none; font-size: 11pt; line-height: 1.7;">
          {{#each this.items}}
          <li style="display: flex; justify-content: space-between; gap: 12pt;">
            <span>▪ {{this.description}}{{#if this.unit}} <span style="color:#666;">({{this.quantity}})</span>{{/if}}</span>
            <strong style="white-space: nowrap;">{{this.price}}</strong>
          </li>
          {{/each}}
        </ul>
        {{!-- Spec per package (kalau ada) --}}
        {{#if this.specs}}
        <div style="margin: 4pt 0 0 24pt;">
          <div style="font-size: 10.5pt; font-style: italic; color: #555; margin-bottom: 2pt;">Specification:</div>
          {{#each this.specs}}
          {{#if this.title}}<div style="font-size: 10pt; font-weight: 600; color: {{../../theme.primaryDark}}; margin-top: 3pt;">{{this.title}}</div>{{/if}}
          <ul style="margin: 0 0 4pt 16pt; padding: 0; line-height: 1.55; font-size: 10.5pt;">
            {{#each this.items}}<li>✓ {{this}}</li>{{/each}}
          </ul>
          {{/each}}
        </div>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{#if showGrandTotal}}
    <div class="terbilang" style="margin-top: 8pt; text-align: right;">
      <strong>{{i18n.grandTotal}}: {{totals.total}}</strong>
    </div>
    {{/if}}
    {{else if doc.isCategorySummary}}
    {{!-- ============================================================
         MODE: CATEGORY SUMMARY — Hide harga & qty per item, hanya total per kategori
         ============================================================ --}}
    <table class="items">
      <thead>
        <tr>
          <th style="width:28pt">{{i18n.no}}</th>
          <th>{{i18n.uraian}}</th>
          <th style="width:140pt">Jumlah</th>
        </tr>
      </thead>
      <tbody>
        {{#each itemGroups}}
          {{#if this.categoryName}}
          <tr class="cat-header">
            <td colspan="3">{{this.categoryName}}</td>
          </tr>
          {{/if}}
          {{#each this.items}}
          <tr>
            <td class="num">{{this.no}}</td>
            <td>
              {{this.description}}
              {{#if this.unit}}<span style="color:#666; font-size:9.5pt;"> · {{this.quantity}}</span>{{/if}}
            </td>
            <td></td>
          </tr>
          {{/each}}
          {{#if this.categoryName}}
          <tr class="cat-subtotal">
            <td colspan="2" style="text-align:right; font-weight:700;">Subtotal {{this.categoryName}}</td>
            <td class="rp" style="font-weight:700;">{{this.subtotalFormatted}}</td>
          </tr>
          {{else}}
          {{!-- Items uncategorized: tampilkan subtotal tanpa label kategori --}}
          <tr class="cat-subtotal">
            <td colspan="2" style="text-align:right; font-weight:700;">Subtotal</td>
            <td class="rp" style="font-weight:700;">{{this.subtotalFormatted}}</td>
          </tr>
          {{/if}}
        {{/each}}
      </tbody>
      <tbody class="grand-totals">
        <tr>
          <td colspan="2" class="label">{{i18n.subtotalKeseluruhan}}</td>
          <td class="rp">{{totals.subtotal}}</td>
        </tr>
        {{#if totals.discount}}
        <tr>
          <td colspan="2" class="label">{{i18n.diskon}}</td>
          <td class="rp">({{totals.discount}})</td>
        </tr>
        {{/if}}
        {{#if totals.taxRate}}
        <tr>
          <td colspan="2" class="label">{{i18n.ppn}} {{totals.taxRate}}%</td>
          <td class="rp">{{totals.taxAmount}}</td>
        </tr>
        {{/if}}
        <tr class="grand-total">
          <td colspan="2" class="label">{{i18n.grandTotal}}</td>
          <td class="rp">{{totals.total}}</td>
        </tr>
      </tbody>
    </table>
    {{else}}
    {{!-- ============================================================
         MODE: DETAILED (default) — Tabel lengkap dengan qty, harga satuan, jumlah per item
         ============================================================ --}}
    <table class="items">
      <thead>
        <tr>
          <th style="width:28pt">{{i18n.no}}</th>
          <th>{{i18n.uraian}}</th>
          <th style="width:72pt">{{i18n.qty}}</th>
          <th style="width:90pt">{{i18n.hargaSatuan}}</th>
          <th style="width:100pt">{{i18n.jumlah}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each itemGroups}}
          {{#if this.categoryName}}
          <tr class="cat-header">
            <td colspan="5">{{this.categoryName}}</td>
          </tr>
          {{/if}}
          {{#each this.items}}
          <tr>
            <td class="num">{{this.no}}</td>
            <td>{{this.description}}</td>
            <td class="qty">{{this.quantity}}</td>
            <td class="rp">{{this.price}}</td>
            <td class="rp">{{this.subtotal}}</td>
          </tr>
          {{/each}}
          {{#if this.categoryName}}
          <tr class="cat-subtotal">
            <td colspan="4" style="text-align:right">Subtotal {{this.categoryName}}</td>
            <td class="rp">{{this.subtotalFormatted}}</td>
          </tr>
          {{/if}}
        {{/each}}
      </tbody>
      <tbody class="grand-totals">
        <tr>
          <td colspan="4" class="label">Subtotal</td>
          <td class="rp">{{totals.subtotal}}</td>
        </tr>
        {{#if totals.discount}}
        <tr>
          <td colspan="4" class="label">{{i18n.diskon}}</td>
          <td class="rp">({{totals.discount}})</td>
        </tr>
        {{/if}}
        {{#if totals.taxRate}}
        <tr>
          <td colspan="4" class="label">{{i18n.ppn}} {{totals.taxRate}}%</td>
          <td class="rp">{{totals.taxAmount}}</td>
        </tr>
        {{/if}}
        {{#if packagePriceFormatted}}
        <tr>
          <td colspan="4" class="label">Total Harga Penawaran</td>
          <td class="rp">{{totals.total}}</td>
        </tr>
        <tr class="grand-total" style="background:{{theme.primarySubtle}};">
          <td colspan="4" class="label">Harga Paket</td>
          <td class="rp">{{packagePriceFormatted}}</td>
        </tr>
        {{else}}
        <tr class="grand-total">
          <td colspan="4" class="label">{{i18n.grandTotal}}</td>
          <td class="rp">{{totals.total}}</td>
        </tr>
        {{/if}}
      </tbody>
    </table>
    {{/if}}

    <div class="terbilang">{{i18n.terbilang}}: <strong>{{totals.totalTerbilang}}</strong></div>

    {{!-- Specifications section — render kalau di-set di Quotation (PDF Nukahiji style) --}}
    {{#if specifications}}
    <div class="text-section" style="margin-top: 14pt;">
      <div class="section-title">Spesifikasi</div>
      {{#each specifications}}
      <div style="margin-top: 4pt;">
        {{#if this.title}}
        <div style="font-weight: 700; color: {{../theme.primaryDark}}; margin-bottom: 2pt;">▪ {{this.title}}</div>
        {{/if}}
        <ul style="margin: 0 0 6pt 24pt; padding: 0; line-height: 1.6; font-size: 10.5pt;">
          {{#each this.items}}<li>✓ {{this}}</li>{{/each}}
        </ul>
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{!-- Payment schedule — kalau di-set, override DP/pelunasan default. Tampil di section sendiri. --}}
    {{#if paymentSchedule}}
    <div class="text-section" style="margin-top: 12pt;">
      <div class="section-title">{{i18n.sistemPembayaran}}</div>
      <ul style="margin: 0 0 0 18pt; padding: 0; line-height: 1.7;">
        {{#each paymentSchedule}}
        <li>
          <strong>{{this.label}} {{this.percent}}%</strong> sebesar <strong>{{this.amountFormatted}}</strong>
          <em style="color:#555;">({{this.amountTerbilang}})</em>
        </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if doc.isInvoice}}
    {{#if doc.amountToPayFormatted}}
    <div style="margin-top: 14pt; padding: 12pt 16pt; background: {{theme.primaryLight}}; border: 2pt solid {{theme.primary}}; border-radius: 6pt;">
      <div style="font-size: 10pt; font-weight: 700; color: {{theme.primaryDark}}; text-transform: uppercase; letter-spacing: .5pt; margin-bottom: 4pt;">
        {{#eq doc.invoicePart "DP"}}JUMLAH YANG DITAGIH (DP){{/eq}}
        {{#eq doc.invoicePart "PELUNASAN"}}JUMLAH YANG DITAGIH (PELUNASAN){{/eq}}
        {{#eq doc.invoicePart "FULL"}}JUMLAH YANG DITAGIH{{/eq}}
      </div>
      <div style="font-size: 22pt; font-weight: 800; color: {{theme.primary}}; font-family: 'Calibri',sans-serif;">{{doc.amountToPayFormatted}}</div>
      <div style="font-size: 10pt; font-style: italic; color: #444; margin-top: 4pt;">
        {{i18n.terbilang}}: <strong>{{doc.amountToPayTerbilang}}</strong>
      </div>
    </div>
    {{/if}}
    {{/if}}

    {{#if doc.isInvoice}}
    {{!-- ============= INVOICE FOOTER (rekening + Nb) ============= --}}
    {{#if payment.banks.length}}
    <div class="text-section" style="margin-top: 14pt;">
      <div style="font-size: 11pt; margin-bottom: 4pt;">Pembayaran dapat di transfer melalui rekening berikut:</div>
      {{#each payment.banks}}
      {{#unless @first}}
      <div style="font-size: 10.5pt; font-style: italic; margin: 6pt 0;">atau</div>
      {{/unless}}
      <table style="font-size: 10.5pt; border-collapse: collapse;">
        <tr><td style="padding: 1pt 4pt 1pt 0; vertical-align: top; width: 100pt;">Nama Bank</td><td style="padding: 1pt 0; vertical-align: top;">: {{this.bankName}}</td></tr>
        <tr><td style="padding: 1pt 4pt 1pt 0; vertical-align: top;">Atas nama</td><td style="padding: 1pt 0; vertical-align: top;">: {{this.accountOwner}}</td></tr>
        <tr><td style="padding: 1pt 4pt 1pt 0; vertical-align: top;">No. Rekening</td><td style="padding: 1pt 0; vertical-align: top;">: <strong>{{this.accountNumber}}</strong></td></tr>
      </table>
      {{/each}}
    </div>
    {{/if}}

    {{#if brandTexts.invoiceClosing}}
    <div class="text-section" style="margin-top: 12pt;">
      <div style="font-style: italic; font-weight: 700; text-decoration: underline; margin-bottom: 3pt;">Nb :</div>
      <div class="text-body" style="white-space: pre-line; font-style: italic; font-weight: 600;">{{brandTexts.invoiceClosing}}</div>
    </div>
    {{/if}}
    {{else}}
    {{!-- ============= QUOTATION FOOTER (text panjang sistem pembayaran) ============= --}}
    {{#if brandTexts.disclaimer}}
    <div class="text-section">
      <div class="section-title">{{i18n.catatanHarga}}</div>
      <div class="text-body disclaimer">{{brandTexts.disclaimer}}</div>
    </div>
    {{/if}}

    {{#if brandTexts.paymentTerms}}
    <div class="text-section">
      <div class="section-title">{{i18n.sistemPembayaran}}</div>
      <div class="text-body">{{brandTexts.paymentTerms}}</div>
    </div>
    {{/if}}

    {{#if payment.banks.length}}
    <div class="text-section">
      <div class="section-title">Pembayaran Transfer Ke</div>
      <ul class="bank-list">
        {{#each payment.banks}}
        <li>Bank <strong>{{this.bankName}}</strong> — No. Rek. <strong>{{this.accountNumber}}</strong> a.n. {{this.accountOwner}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    <div class="closing-section">
      <div class="closing-text">{{#if brandTexts.closing}}{{brandTexts.closing}}{{else}}Demikian penawaran ini kami sampaikan. Atas perhatian dan kerjasamanya kami ucapkan terima kasih.{{/if}}</div>
    </div>
    {{/if}}

    <div class="signature">
      <div class="block">
        <div class="role">{{i18n.hormatKami}}<br/><strong>{{company.name}}</strong></div>
        <div class="sign-area">
          {{#if signedBy.stampUrl}}
          <img class="stamp-image" src="{{signedBy.stampUrl}}" alt="Stempel" />
          {{/if}}
          {{#if signedBy.signatureUrl}}
          <img class="sign-image" src="{{signedBy.signatureUrl}}" alt="Tanda Tangan" />
          {{/if}}
        </div>
        <div class="director">{{signedBy.name}}</div>
        <div class="position-label">{{#if signedBy.position}}{{signedBy.position}}{{else}}Marketing{{/if}}</div>
      </div>
    </div>

    <div class="end-spacer"></div>

</div><!-- /.content -->

    </td></tr>
  </tbody>
</table>

</body>
</html>
